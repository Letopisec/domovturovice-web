---
// StepsVertical.astro — statická vertikální postupová lišta.
// Číslo v kruhu vlevo + svislá spojovací linka + obsah vpravo.
// Zdroj: Domov Turovice /prijeti
//
// Props:
//   kicker, heading — nadpis sekce (volitelné)
//   steps[] — { tag?, tagColor? ('green'|'orange'), title, text, note? }
//             note = volitelný zvýrazněný box pod textem (HTML)
const { kicker, heading, steps = [] } = Astro.props;
---
<section class="stepsv-section">
  <div class="container">
    {(kicker || heading) && (
      <div class="section-heading">
        {kicker && <span class="section-label">{kicker}</span>}
        {heading && <h2>{heading}</h2>}
      </div>
    )}
    <ol class="stepsv-list">
      {steps.map((s, i) => (
        <li class="stepsv-item">
          <div class="stepsv-left" aria-hidden="true"><div class="stepsv-num">{i + 1}</div></div>
          <div class="stepsv-body">
            {s.tag && <span class={`stepsv-tag ${s.tagColor || ''}`}>{s.tag}</span>}
            <h3>{s.title}</h3>
            <p set:html={s.text} />
            {s.note && <div class="stepsv-note" set:html={s.note} />}
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .stepsv-section { padding: var(--space-12) 0; }
  .stepsv-list { display: flex; flex-direction: column; gap: 0; position: relative; max-width: 820px; margin: 0 auto; list-style: none; padding: 0; }
  .stepsv-item { display: grid; grid-template-columns: 72px 1fr; gap: 32px; position: relative; }
  /* Svislá spojovací linka mezi kruhy */
  .stepsv-item:not(:last-child)::after {
    content: ''; position: absolute; left: 35px; top: 72px; bottom: 0;
    width: 2px; background: var(--color-border);
  }
  .stepsv-left { display: flex; flex-direction: column; align-items: center; padding-top: 4px; }
  .stepsv-num {
    width: 52px; height: 52px; border-radius: 50%;
    background: var(--color-primary); color: var(--color-white);
    font-family: var(--font-serif); font-size: var(--text-2xl); font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; position: relative; z-index: 1;
  }
  .stepsv-body { padding-bottom: 48px; }
  .stepsv-item:last-child .stepsv-body { padding-bottom: 0; }
  .stepsv-body h3 { margin-bottom: 10px; margin-top: 12px; font-family: var(--font-serif); font-size: var(--text-xl); color: var(--color-primary); }
  .stepsv-body p { color: var(--color-text); margin-bottom: 14px; max-width: 580px; line-height: var(--leading-body); }
  .stepsv-body p:last-child { margin-bottom: 0; }
  .stepsv-tag { display: inline-block; font-size: var(--text-xs); font-weight: 700; padding: 4px 12px; border-radius: 100px; margin-bottom: 10px; background: var(--color-primary-soft); color: var(--color-primary); }
  .stepsv-tag.green { background: var(--color-primary-ghost); color: var(--color-primary); }
  .stepsv-tag.orange { background: var(--color-accent-light); color: var(--color-accent); }
  .stepsv-note {
    background: var(--color-white); border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-primary);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: 14px 18px; margin-top: 12px; max-width: 520px;
  }
  .stepsv-note :global(p) { font-size: var(--text-body); color: var(--color-text-muted); margin: 0; }
  .stepsv-note :global(strong) { color: var(--color-text); }
  @media (max-width: 768px) {
    .stepsv-section { padding: var(--space-8) 0; }
    .stepsv-item { grid-template-columns: 52px 1fr; gap: 20px; }
    .stepsv-item:not(:last-child)::after { left: 25px; top: 60px; }
    .stepsv-num { width: 44px; height: 44px; font-size: var(--text-xl); }
  }
</style>
