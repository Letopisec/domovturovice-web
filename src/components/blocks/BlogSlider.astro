---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'clanky'>[];
  limit?: number;
  allPostsUrl?: string;
  allPostsLabel?: string;
  heading?: string;
  label?: string;
}

const {
  posts: rawPosts,
  limit = 6,
  allPostsUrl = '/blog',
  allPostsLabel = 'Všechny příspěvky →',
  heading = 'Nejnovější příspěvky',
  label = 'Blog',
} = Astro.props;

const posts = rawPosts.slice(0, limit);

const uid = Math.random().toString(36).slice(2, 7);

function formatDate(date: Date): string {
  return date.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<section class="bs-section">
  <div class="container">
    <div class="blog-header">
      <div>
        <span class="section-label">{label}</span>
        <h2 class="section-h2" style="margin-bottom:0">{heading}</h2>
      </div>
      {allPostsUrl && (
        <a href={allPostsUrl} class="btn btn-secondary">{allPostsLabel}</a>
      )}
    </div>
    <div class="blog-track-outer">
      <div class="blog-track" id={`blogTrack-${uid}`}>
        {posts.map(post => (
          <a href={`/${post.slug}`} class="blog-card">
            {post.data.nahled
              ? <img class="blog-card-img" src={post.data.nahled} alt={post.data.titulek} loading="lazy" />
              : <div class="blog-card-img blog-card-img-placeholder"></div>
            }
            <div class="blog-card-body">
              <span class="blog-cat">{post.data.kategorie}</span>
              <div class="blog-card-date">{formatDate(post.data.datum)}</div>
              <h3>{post.data.titulek}</h3>
              <p>{post.data.perex}</p>
              <span class="blog-more">Číst více →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
    <div class="blog-nav">
      <button class="blog-btn" id={`blogPrev-${uid}`} aria-label="Předchozí">
        <svg viewBox="0 0 24 24"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"/></svg>
      </button>
      <div class="blog-dots" id={`blogDots-${uid}`}></div>
      <button class="blog-btn" id={`blogNext-${uid}`} aria-label="Následující">
        <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
      </button>
    </div>
  </div>
</section>

<style>
.bs-section {
  background: var(--clr-bg);
  overflow: hidden;
  padding: 64px 0 80px;
}
.blog-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 40px;
  flex-wrap: wrap;
  gap: 16px;
}
.blog-track-outer { overflow: hidden; }
.blog-track {
  display: flex;
  transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}
.blog-card {
  flex: 0 0 calc(33.333% - 11px);
  margin-right: 16px;
  background: #fff;
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  transition: box-shadow 0.25s;
  cursor: pointer;
  text-decoration: none;
}
.blog-card:hover { box-shadow: var(--shadow-hover); text-decoration: none; }
.blog-card-img {
  width: 100%;
  height: 196px;
  object-fit: cover;
  display: block;
}
.blog-card-img-placeholder {
  background: var(--clr-bg-alt);
  aspect-ratio: 16/9;
  height: 196px;
}
.blog-card-body { padding: 20px 22px 24px; }
.blog-cat {
  font-family: var(--ff-body);
  font-size: var(--font-size-label);
  font-weight: 700;
  letter-spacing: 0.10em;
  text-transform: uppercase;
  color: var(--clr-primary);
  margin-bottom: 8px;
  display: block;
}
.blog-card-date {
  font-family: var(--ff-body);
  font-size: var(--font-size-meta);
  line-height: 1.45;
  color: var(--clr-muted);
  margin-bottom: 6px;
}
.blog-card h3 {
  font-family: var(--ff-head);
  font-size: var(--font-size-h4);
  font-weight: 600;
  color: var(--clr-heading);
  margin-bottom: 8px;
  transition: color 0.25s;
  line-height: 1.3;
}
.blog-card:hover h3 { color: var(--clr-primary); }
.blog-card p {
  font-family: var(--ff-body);
  font-size: var(--font-size-base);
  line-height: 1.65;
  color: var(--clr-text);
  margin-bottom: 14px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.blog-more {
  font-family: var(--ff-body);
  font-size: var(--font-size-caption);
  font-weight: 600;
  color: var(--clr-primary);
  text-decoration: none;
}
.blog-nav {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 32px;
  justify-content: center;
}
.blog-btn {
  width: 44px; height: 44px;
  border-radius: 50%;
  border: 2px solid var(--clr-primary);
  background: transparent;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  flex-shrink: 0;
}
.blog-btn:hover { background: var(--clr-primary); }
.blog-btn svg { width: 20px; height: 20px; fill: var(--clr-primary); transition: fill 0.2s; }
.blog-btn:hover svg { fill: white; }
.blog-dots { display: flex; gap: 8px; }
.blog-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--clr-border);
  border: none;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
  padding: 0;
}
.blog-dot.active { background: var(--clr-primary); transform: scale(1.3); }

@media (max-width: 1024px) {
  .blog-card { flex: 0 0 calc(50% - 8px); }
}
@media (max-width: 768px) {
  .blog-card { flex: 0 0 100%; }
  .bs-section { padding: 44px 0 56px; }
}
</style>

<script define:vars={{ uid }}>
  (function () {
    const track = document.getElementById('blogTrack-' + uid);
    const dotsContainer = document.getElementById('blogDots-' + uid);
    const prevBtn = document.getElementById('blogPrev-' + uid);
    const nextBtn = document.getElementById('blogNext-' + uid);

    if (!track || !dotsContainer) return;

    const cards = track.querySelectorAll('.blog-card');
    const total = cards.length;
    const visibleCount = () => window.innerWidth > 1024 ? 3 : window.innerWidth > 768 ? 2 : 1;
    let current = 0;
    let autoInterval;

    function maxSlide() { return Math.max(0, total - visibleCount()); }

    function buildDots() {
      dotsContainer.innerHTML = '';
      for (let i = 0; i <= maxSlide(); i++) {
        const dot = document.createElement('button');
        dot.className = 'blog-dot' + (i === current ? ' active' : '');
        dot.setAttribute('aria-label', 'Přejít na článek ' + (i + 1));
        dot.setAttribute('aria-current', i === current ? 'true' : 'false');
        dot.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(dot);
      }
    }

    function goTo(idx) {
      current = Math.max(0, Math.min(idx, maxSlide()));
      const cardWidth = cards[0].offsetWidth + 16;
      track.style.transform = 'translateX(-' + (current * cardWidth) + 'px)';
      dotsContainer.querySelectorAll('.blog-dot').forEach((d, i) => {
        d.classList.toggle('active', i === current);
        d.setAttribute('aria-current', i === current ? 'true' : 'false');
      });
    }

    function startAuto() {
      autoInterval = setInterval(() => goTo(current < maxSlide() ? current + 1 : 0), 4000);
    }

    track.addEventListener('mouseenter', () => clearInterval(autoInterval));
    track.addEventListener('mouseleave', startAuto);
    if (prevBtn) prevBtn.addEventListener('click', () => goTo(current - 1));
    if (nextBtn) nextBtn.addEventListener('click', () => goTo(current + 1));

    buildDots();
    startAuto();
    window.addEventListener('resize', () => { buildDots(); goTo(Math.min(current, maxSlide())); });
  })();
</script>
