---
// FaqAccordion.astro — rozbalovací otázky a odpovědi
// Props: kicker, heading, items[] (question, answer), aside (volitelný HTML blok vpravo)
const { kicker, heading, items = [] } = Astro.props;
---
<section class="faq-section">
  <div class="container">
    <div class="section-heading">
      {kicker && <span class="section-label">{kicker}</span>}
      {heading && <h2>{heading}</h2>}
    </div>
    <div class="faq-list">
      {items.map((it) => (
        <div class="faq-item">
          <button class="faq-question">{it.question}<span class="faq-question__icon">+</span></button>
          <div class="faq-answer"><p set:html={it.answer} /></div>
        </div>
      ))}
    </div>
  </div>
</section>
<script>
  document.querySelectorAll('.faq-question').forEach((q) => {
    q.addEventListener('click', () => q.closest('.faq-item')?.classList.toggle('is-open'));
  });
</script>
