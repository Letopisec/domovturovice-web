---
// Steps.astro — číslované kroky procesu
// Props: kicker, heading, lead, steps[] (title, text), columns, link
const { kicker, heading, lead, steps = [], columns = 4, link } = Astro.props;
---
<section class="steps-section">
  <div class="container">
    {kicker && <span class="section-label">{kicker}</span>}
    {heading && <h2>{heading}</h2>}
    {lead && <p class="steps-lead">{lead}</p>}
    <div class="steps-grid" style={`grid-template-columns: repeat(${columns}, 1fr)`}>
      <div class="steps-connector"></div>
      {steps.map((s) => (
        <div class="step-item">
          <div class="step-num">{steps.indexOf(s) + 1}</div>
          <p class="step-title">{s.title}</p>
          <p>{s.text}</p>
        </div>
      ))}
    </div>
    {link && (
      <div class="steps-cta">
        <a href={link.href} class="about-link" style="justify-content:center">
          {link.text} <i class="ti ti-arrow-right"></i>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .steps-section { padding: var(--space-12) 0; }
  .steps-lead {
    font-size: var(--text-perex);
    color: var(--color-text-muted);
    max-width: 680px;
    margin: 0 0 var(--space-6);
    line-height: var(--leading-body);
  }
  .steps-grid {
    display: grid;
    gap: 32px;
    position: relative;
  }
  .steps-connector {
    position: absolute;
    top: 28px;
    left: calc(12.5% + 20px);
    right: calc(12.5% + 20px);
    height: 0;
    border-top: 1px dashed var(--color-border);
    pointer-events: none;
  }
  .step-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
  }
  .step-num {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-primary-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: var(--text-display-sm);
    font-weight: 700;
    color: var(--color-primary);
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .step-title {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 600;
    line-height: 1.40;
    color: var(--color-dark);
    margin: 0;
  }
  .step-item p {
    font-size: var(--text-body);
    line-height: 1.65;
    color: var(--color-text);
  }
  .steps-cta {
    margin-top: 48px;
    text-align: center;
  }
  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-primary);
    font-weight: 600;
    font-size: var(--text-body);
  }
  .about-link:hover { text-decoration: underline; }
  @media (max-width: 768px) {
    .steps-grid { grid-template-columns: 1fr !important; gap: 28px; }
    .steps-connector { display: none; }
  }
</style>
