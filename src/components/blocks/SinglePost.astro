---
// ════════════════════════════════════════════════════════════════
// SinglePost — detail článku (port Molti "Single Post · varianta 2")
// Full-width header (nadpis + meta + cover) + 3/4 obsah + 1/4 sticky sidebar.
// Bez autor-widgetu (autor jen jako jméno v meta liště).
// Vše na tokenech projektu (--clr-*, --ff-*, --text-*, --space-*, --radius-*).
//
// Props:
//   titulek, datum (Date), kategorie, stitky[], nahled?, autor
//   katSlug         – slug kategorie (odkaz na rozcestník)
//   stitkySlugy[]   – [{ nazev, slug }] pro odkazy štítků
//   kategorieList[] – [{ nazev, slug, pocet }] do sidebaru
//   dalsiClanky[]   – [{ titulek, slug, datum (Date), nahled? }] do sidebaru
//   prev?, next?    – [{ titulek, slug }] navigace; volitelné
// Slot = vyrenderované tělo článku (<Content />).
// ════════════════════════════════════════════════════════════════
interface NavItem { titulek: string; slug: string; }
interface KatItem { nazev: string; slug: string; pocet: number; }
interface DalsiItem { titulek: string; slug: string; datum: Date; nahled?: string; }
interface StitekItem { nazev: string; slug: string; }

interface Props {
  titulek: string;
  datum: Date;
  kategorie: string;
  katSlug: string;
  stitkySlugy?: StitekItem[];
  nahled?: string;
  autor: string;
  kategorieList?: KatItem[];
  dalsiClanky?: DalsiItem[];
  prev?: NavItem | null;
  next?: NavItem | null;
}

const {
  titulek, datum, kategorie, katSlug,
  stitkySlugy = [], nahled, autor,
  kategorieList = [], dalsiClanky = [], prev = null, next = null,
} = Astro.props;

function fmt(d: Date): string {
  return d.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<div class="sp-page">

  <!-- FULL-WIDTH BLOK: meta + nadpis + cover -->
  <div class="sp2-fullwidth">
    <div class="sp-meta-bar">
      <div class="sp-meta">
        <span>{autor}</span>
        <span class="sp-meta-sep">|</span>
        <span>{fmt(datum)}</span>
        <span class="sp-meta-sep">|</span>
        <a class="sp-meta-cat" href={`/${katSlug}`}>{kategorie}</a>
      </div>
      <h1 class="sp-title">{titulek}</h1>
    </div>

    {nahled && (
      <div class="sp-cover" style={`background-image:url('${nahled}')`}></div>
    )}
  </div>

  <!-- LAYOUT: 3/4 text + 1/4 sidebar -->
  <div class="sp2-layout">

    <!-- Textová karta -->
    <div class="sp2-body-wrap">
      <div class="sp-body">
        <div class="sp-content">
          <slot />
        </div>
      </div>

      {stitkySlugy.length > 0 && (
        <div class="sp-footer">
          <span class="sp-footer-label">Štítky:</span>
          {stitkySlugy.map((t) => <a href={`/${t.slug}`} class="sp-tag">{t.nazev}</a>)}
        </div>
      )}

      {(prev || next) && (
        <div class="sp-nav">
          {prev ? (
            <a href={`/${prev.slug}`} class="sp-nav-item prev">
              <div class="sp-nav-dir">← Předchozí</div>
              <div class="sp-nav-title">{prev.titulek}</div>
            </a>
          ) : <span class="sp-nav-item prev sp-nav-empty"></span>}
          {next ? (
            <a href={`/${next.slug}`} class="sp-nav-item next">
              <div class="sp-nav-dir">Následující →</div>
              <div class="sp-nav-title">{next.titulek}</div>
            </a>
          ) : <span class="sp-nav-item next sp-nav-empty"></span>}
        </div>
      )}
    </div>

    <!-- Sidebar: Kategorie + Další příspěvky -->
    <aside class="sp2-sidebar">

      {kategorieList.length > 0 && (
        <div class="bl-widget">
          <div class="bl-widget-title">Kategorie</div>
          <ul class="bl-cat-widget-list">
            {kategorieList.map((k) => (
              <li class="bl-cat-widget-item">
                <a href={`/${k.slug}`} class="bl-cat-link">
                  <span class="bl-cat-arrow">→</span>
                  <span class="bl-cat-name">{k.nazev}</span>
                  <span class="bl-cat-count">({k.pocet})</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {dalsiClanky.length > 0 && (
        <div class="bl-widget">
          <div class="bl-widget-title">Další příspěvky</div>
          {dalsiClanky.map((c) => (
            <a href={`/${c.slug}`} class="sp-recent-item">
              <div class="sp-recent-thumb" style={c.nahled ? `background-image:url('${c.nahled}')` : ''}></div>
              <div class="sp-recent-info">
                <div class="sp-recent-title">{c.titulek}</div>
                <div class="sp-recent-date">{fmt(c.datum)}</div>
              </div>
            </a>
          ))}
        </div>
      )}

    </aside>

  </div>
</div>

<style>
  .sp-page { max-width: 1100px; margin: 0 auto; padding: var(--space-8) 0 var(--space-12); }

  /* ── FULL-WIDTH HEADER ── */
  .sp2-fullwidth {
    background: #fff;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,.07);
  }
  .sp-meta-bar { padding: var(--space-6) var(--space-8) var(--space-4); }
  .sp-meta {
    font-size: var(--text-meta);
    color: var(--clr-muted);
    display: flex; gap: 6px; align-items: center; flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }
  .sp-meta-cat { color: var(--clr-primary); font-weight: 700; text-decoration: none; }
  .sp-meta-cat:hover { text-decoration: underline; }
  .sp-meta-sep { color: var(--clr-border); }
  .sp-title {
    font-family: var(--ff-head);
    font-size: clamp(26px, 3vw, 42px);
    font-weight: 700;
    color: var(--clr-heading);
    line-height: 1.2;
  }

  /* ── COVER PŘES CELOU ŠÍŘKU ── */
  .sp-cover {
    width: 100%;
    height: 420px;
    background-color: var(--clr-primary-soft);
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
  }

  /* ── LAYOUT 3/4 + 1/4 ── */
  .sp2-layout {
    display: grid;
    grid-template-columns: 3fr 1fr;
    gap: 0 var(--space-6);
    align-items: start;
  }
  .sp2-body-wrap {
    background: #fff;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    box-shadow: 0 2px 8px rgba(0,0,0,.07);
    overflow: hidden;
  }
  .sp-body { padding: var(--space-8); }

  /* ── TYPOGRAFIE OBSAHU ── */
  .sp-content :global(h2) {
    font-family: var(--ff-head);
    font-size: 22px; font-weight: 700;
    color: var(--clr-heading);
    margin: var(--space-6) 0 var(--space-3);
    line-height: 1.3;
  }
  .sp-content :global(h3) {
    font-family: var(--ff-head);
    font-size: 18px; font-weight: 700;
    color: var(--clr-heading);
    margin: var(--space-5) 0 var(--space-2);
  }
  .sp-content :global(p) {
    font-size: 15px; line-height: 1.85;
    color: var(--clr-text-body);
    margin-bottom: var(--space-4);
  }
  .sp-content :global(p:first-child) {
    font-size: 16px; font-weight: 500;
    color: var(--clr-heading); line-height: 1.9;
  }
  .sp-content :global(strong) { color: var(--clr-heading); font-weight: 700; }
  .sp-content :global(ul), .sp-content :global(ol) {
    padding-left: 24px; margin-bottom: var(--space-4);
  }
  .sp-content :global(li) {
    font-size: 15px; line-height: 1.75;
    color: var(--clr-text-body); margin-bottom: 6px;
  }
  .sp-content :global(blockquote) {
    border-left: 4px solid var(--clr-primary);
    background: var(--clr-primary-soft);
    padding: var(--space-3) var(--space-4);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    margin: var(--space-5) 0;
  }
  .sp-content :global(blockquote p) {
    font-size: 16px; font-style: italic;
    color: var(--clr-heading); margin: 0;
  }
  .sp-content :global(a) {
    color: var(--clr-primary); text-decoration: none;
    border-bottom: 1px solid var(--clr-primary-soft);
    transition: border-color .2s, color .2s;
  }
  .sp-content :global(a:hover) { color: var(--clr-primary-hover); border-bottom-color: var(--clr-primary); }
  .sp-content :global(img) { width: 100%; border-radius: var(--radius-md); margin: var(--space-5) 0; }

  /* tabulka */
  .sp-content :global(table) {
    width: 100%; border-collapse: collapse;
    margin: var(--space-5) 0; font-size: 14px;
  }
  .sp-content :global(thead th) {
    background: var(--clr-primary-soft); color: var(--clr-heading);
    font-weight: 700; text-align: left;
    padding: var(--space-2) var(--space-3);
    border-bottom: 2px solid var(--clr-primary);
  }
  .sp-content :global(tbody td) {
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--clr-border);
  }
  .sp-content :global(tbody tr:nth-child(even)) { background: var(--clr-bg-alt); }

  /* ── TAGY ── */
  .sp-footer {
    padding: var(--space-4) var(--space-8) var(--space-5);
    border-top: 1px solid var(--clr-bg-alt);
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  }
  .sp-footer-label {
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .1em; color: var(--clr-muted);
  }
  .sp-tag {
    display: inline-block; padding: 4px 12px;
    background: var(--clr-bg-alt); border-radius: var(--radius-md);
    font-size: 12px; font-weight: 600; color: var(--clr-text-body);
    text-decoration: none; transition: background .2s, color .2s;
  }
  .sp-tag:hover { background: var(--clr-primary-soft); color: var(--clr-primary); }

  /* ── NAVIGACE ── */
  .sp-nav {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1px; background: var(--clr-border);
  }
  .sp-nav-item {
    background: var(--clr-bg-alt); padding: var(--space-4) var(--space-5);
    text-decoration: none; display: flex; flex-direction: column; gap: 4px;
    transition: background .2s;
  }
  .sp-nav-item:hover { background: var(--clr-primary-soft); }
  .sp-nav-empty { pointer-events: none; }
  .sp-nav-item.next { text-align: right; }
  .sp-nav-dir {
    font-size: 10px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .12em; color: var(--clr-muted);
  }
  .sp-nav-title {
    font-family: var(--ff-head); font-size: 14px; font-weight: 700;
    color: var(--clr-heading); line-height: 1.3; transition: color .2s;
  }
  .sp-nav-item:hover .sp-nav-title { color: var(--clr-primary); }

  /* ── SIDEBAR ── */
  .sp2-sidebar {
    position: sticky; top: 20px;
    display: flex; flex-direction: column; gap: var(--space-5);
    padding-top: var(--space-6);
  }
  .bl-widget {
    background: #fff; border: 1px solid var(--clr-border);
    border-radius: var(--radius-lg); padding: var(--space-5);
    box-shadow: 0 2px 8px rgba(0,0,0,.07);
  }
  .bl-widget-title {
    font-family: var(--ff-head); font-size: 16px; font-weight: 700;
    color: var(--clr-primary); margin-bottom: var(--space-4);
  }

  /* kategorie */
  .bl-cat-widget-list { list-style: none; margin: 0; padding: 0; }
  .bl-cat-widget-item { border-bottom: 1px solid var(--clr-bg-alt); }
  .bl-cat-widget-item:last-child { border-bottom: none; }
  .bl-cat-link {
    display: flex; align-items: center; gap: 0;
    padding: 10px 0; font-size: 14px; color: var(--clr-heading);
    font-weight: 500; text-decoration: none; transition: color .2s;
  }
  .bl-cat-arrow {
    display: inline-block; width: 0; overflow: hidden;
    color: var(--clr-primary); font-weight: 700; font-size: 14px;
    transition: width .2s ease; white-space: nowrap;
  }
  .bl-cat-name { flex: 1; transition: color .2s, padding-left .2s ease; }
  .bl-cat-count { font-size: 12px; color: var(--clr-muted); flex-shrink: 0; }
  .bl-cat-link:hover .bl-cat-arrow { width: 18px; }
  .bl-cat-link:hover .bl-cat-name { color: var(--clr-primary); padding-left: 4px; }

  /* další příspěvky */
  .sp-recent-item {
    display: flex; gap: 12px; padding: 10px 0;
    border-bottom: 1px solid var(--clr-bg-alt);
    text-decoration: none;
  }
  .sp-recent-item:last-child { border-bottom: none; }
  .sp-recent-thumb {
    width: 60px; height: 48px; border-radius: var(--radius-sm);
    flex-shrink: 0; background-color: var(--clr-primary-soft);
    background-position: center; background-size: cover;
  }
  .sp-recent-info { flex: 1; }
  .sp-recent-title {
    font-family: var(--ff-head); font-size: 13px; font-weight: 700;
    color: var(--clr-heading); line-height: 1.35; margin-bottom: 3px;
    transition: color .2s;
  }
  .sp-recent-item:hover .sp-recent-title { color: var(--clr-primary); }
  .sp-recent-date { font-size: 11px; color: var(--clr-muted); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .sp2-layout { grid-template-columns: 1fr; }
    .sp2-body-wrap { border-radius: 0; }
    .sp2-sidebar { position: static; padding-top: var(--space-6); }
  }
  @media (max-width: 600px) {
    .sp-meta-bar { padding: var(--space-5) var(--space-5) var(--space-3); }
    .sp-body { padding: var(--space-5); }
    .sp-cover { height: 240px; }
    .sp-nav { grid-template-columns: 1fr; }
    .sp-footer { padding: var(--space-4) var(--space-5); }
  }
</style>
