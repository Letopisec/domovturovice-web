---
// ════════════════════════════════════════════════════════════════
// SinglePost — detail článku (port Molti "Single Post · varianta 2")
// Full-width header (nadpis + meta + cover) + 3/4 obsah + 1/4 sticky sidebar.
// Bez autor-widgetu (autor jen jako jméno v meta liště).
// Vše na tokenech projektu (--clr-*, --ff-*, --text-*, --space-*, --radius-*).
//
// Props:
//   titulek, datum (Date), kategorie, stitky[], nahled?, autor
//   katSlug         – slug kategorie (odkaz na rozcestník)
//   stitkySlugy[]   – [{ nazev, slug }] pro odkazy štítků
//   kategorieList[] – [{ nazev, slug, pocet }] do sidebaru
//   dalsiClanky[]   – [{ titulek, slug, datum (Date), nahled? }] do sidebaru
//   prev?, next?    – [{ titulek, slug }] navigace; volitelné
// Slot = vyrenderované tělo článku (<Content />).
// ════════════════════════════════════════════════════════════════
interface NavItem { titulek: string; slug: string; }
interface KatItem { nazev: string; slug: string; pocet: number; }
interface DalsiItem { titulek: string; slug: string; datum: Date; nahled?: string; }
interface StitekItem { nazev: string; slug: string; }

interface Props {
  titulek: string;
  datum: Date;
  kategorie: string;
  katSlug: string;
  stitkySlugy?: StitekItem[];
  nahled?: string;
  autor: string;
  zdroj?: string;
  kategorieList?: KatItem[];
  dalsiClanky?: DalsiItem[];
  prev?: NavItem | null;
  next?: NavItem | null;
}

const {
  titulek, datum, kategorie, katSlug,
  stitkySlugy = [], nahled, autor, zdroj,
  kategorieList = [], dalsiClanky = [], prev = null, next = null,
} = Astro.props;

function fmt(d: Date): string {
  return d.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<div class="sp-section">

  <!-- HERO — přes celou šířku, mimo sp-page -->
  <div class="sp2-hero">
    <div class="sp2-hero-inner">
      <div class="sp-meta">
        <span>{autor}</span>
        <span class="sp-meta-sep">|</span>
        <span>{fmt(datum)}</span>
        <span class="sp-meta-sep">|</span>
        <a class="sp-meta-cat-hero" href={`/${katSlug}`}>{kategorie}</a>
      </div>
      <h1 class="sp-title-hero">{titulek}</h1>
    </div>
  </div>

  {nahled && (
    <div class="sp-cover-full" style={`background-image:url('${nahled}')`}></div>
  )}

<div class="sp-page">

  <!-- LAYOUT: 3/4 text + 1/4 sidebar -->
  <div class="sp2-layout">

    <!-- Textová karta -->
    <div class="sp2-body-wrap">
      <div class="sp-body">
        <div class="sp-content">
          <slot />
        </div>
        {zdroj && (
          <div class="sp-source">
            <span class="sp-source-label">Zdroj:</span>
            {zdroj.startsWith('http')
              ? <a href={zdroj} target="_blank" rel="noopener noreferrer" class="sp-source-link">{zdroj}</a>
              : <span class="sp-source-text">{zdroj}</span>
            }
          </div>
        )}
      </div>

      {(prev || next) && (
        <div class="sp-nav">
          {prev ? (
            <a href={`/${prev.slug}`} class="sp-nav-item prev">
              <div class="sp-nav-dir">← Předchozí</div>
              <div class="sp-nav-title">{prev.titulek}</div>
            </a>
          ) : <span class="sp-nav-item prev sp-nav-empty"></span>}
          {next ? (
            <a href={`/${next.slug}`} class="sp-nav-item next">
              <div class="sp-nav-dir">Následující →</div>
              <div class="sp-nav-title">{next.titulek}</div>
            </a>
          ) : <span class="sp-nav-item next sp-nav-empty"></span>}
        </div>
      )}
    </div>

    <!-- Sidebar: Kategorie + Další příspěvky -->
    <aside class="sp2-sidebar">

      {kategorieList.length > 0 && (
        <div class="bl-widget">
          <div class="bl-widget-title">Kategorie</div>
          <ul class="bl-cat-widget-list">
            {kategorieList.map((k) => (
              <li class="bl-cat-widget-item">
                <a href={`/${k.slug}`} class="bl-cat-link">
                  <span class="bl-cat-arrow">→</span>
                  <span class="bl-cat-name">{k.nazev}</span>
                  <span class="bl-cat-count">({k.pocet})</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {dalsiClanky.length > 0 && (
        <div class="bl-widget">
          <div class="bl-widget-title">Další příspěvky</div>
          {dalsiClanky.map((c) => (
            <a href={`/${c.slug}`} class="sp-recent-item">
              <div class="sp-recent-thumb" style={c.nahled ? `background-image:url('${c.nahled}')` : ''}></div>
              <div class="sp-recent-info">
                <div class="sp-recent-title">{c.titulek}</div>
                <div class="sp-recent-date">{fmt(c.datum)}</div>
              </div>
            </a>
          ))}
        </div>
      )}

    </aside>

  </div>
</div>
</div>

<style>
  /* ── SEKCE s kontrastním pozadím (bílé karty vyniknou) ── */
  .sp-section {
    background: var(--clr-bg);
    padding: 3rem 1.5rem;
    margin-bottom: 4rem;
  }
  .sp-page { max-width: 1100px; margin: 0 auto; }

  /* ── HERO (Turovice varianta — burgundy přes celou šířku) ── */
  .sp2-hero {
    background: var(--clr-primary);
    width: 100vw;
    margin-left: calc(-1.5rem);
    padding: 3rem 0 2.5rem;
  }
  .sp2-hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .sp-meta {
    font-size: var(--font-size-meta);
    color: rgba(255,255,255,.75);
    display: flex; gap: 6px; align-items: center; flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .sp-meta-sep { color: rgba(255,255,255,.4); }
  .sp-meta-cat-hero { color: #fff; font-weight: 700; text-decoration: none; }
  .sp-meta-cat-hero:hover { text-decoration: underline; }
  .sp-title-hero {
    font-family: var(--ff-head);
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin: 0;
  }

  /* ── COVER — nalepená přímo pod hero, žádná mezera ── */
  .sp-cover-full {
    width: 100vw;
    margin-left: calc(-1.5rem);
    height: 380px;
    background-color: var(--clr-primary-soft);
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    margin-bottom: 0;
  }

  /* ── LAYOUT 2/3 + 1/3 ── */
  .sp2-layout {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 0 1.75rem;
    align-items: start;
  }
  .sp2-body-wrap {
    background: #fff;
    border-radius: 0 0 var(--radius-card) var(--radius-card);
    box-shadow: 0 2px 8px rgba(0,0,0,.07);
    overflow: hidden;
  }
  .sp-body { padding: 2.5rem; }

  /* ── TYPOGRAFIE OBSAHU ──
     POZN: slotovaný markdown nedědí data-astro-cid komponenty,
     proto :global() + dostatečná specificita přes .sp-content */
  .sp-content :global(h2) {
    font-family: var(--ff-head);
    font-size: 28px; font-weight: 700;
    color: var(--clr-heading);
    margin: 2.5rem 0 1rem;
    line-height: 1.3;
  }
  .sp-content :global(h2:first-child),
  .sp-content :global(h3:first-child) { margin-top: 0; }
  .sp-content :global(h3) {
    font-family: var(--ff-head);
    font-size: 21px; font-weight: 700;
    color: var(--clr-heading);
    margin: 2rem 0 .75rem;
    line-height: 1.3;
  }
  .sp-content :global(p) {
    font-size: var(--font-size-base); line-height: 1.8;
    color: var(--clr-text-body);
    margin: 0 0 1.25rem;
  }
  .sp-content :global(> p:first-child) {
    font-size: var(--font-size-perex); font-weight: 500;
    color: var(--clr-heading); line-height: 1.7;
  }
  .sp-content :global(strong) { color: var(--clr-heading); font-weight: 700; }

  .sp-content :global(em) {
    font-style: italic;
    color: var(--clr-text-body);
  }

  .sp-content :global(blockquote strong) {
    display: block;
    margin-top: .75rem;
    font-size: var(--font-size-caption);
    font-style: normal;
    font-weight: 600;
    color: var(--clr-primary);
    letter-spacing: .02em;
  }

  .sp-source {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--clr-border);
    font-size: var(--font-size-caption);
    color: var(--clr-muted);
    display: flex;
    gap: 6px;
    align-items: baseline;
  }
  .sp-source-label { font-weight: 600; }
  .sp-source-link { color: var(--clr-primary); text-decoration: underline; }
  .sp-source-link:hover { color: var(--clr-primary-hover); }

  .sp-content :global(ul), .sp-content :global(ol) {
    padding-left: 1.5rem; margin: 0 0 1.25rem;
  }
  .sp-content :global(li) {
    font-size: var(--font-size-base); line-height: 1.7;
    color: var(--clr-text-body); margin-bottom: .5rem;
  }
  .sp-content :global(blockquote) {
    border-left: 4px solid var(--clr-primary);
    background: var(--clr-primary-soft);
    padding: 1.25rem 1.5rem;
    border-radius: 0 var(--radius-card) var(--radius-card) 0;
    margin: 1.75rem 0;
  }
  .sp-content :global(blockquote p) {
    font-size: var(--font-size-subhead); font-style: italic;
    color: var(--clr-heading); margin: 0;
  }
  .sp-content :global(a) {
    color: var(--clr-primary); text-decoration: underline;
    transition: color .2s;
  }
  .sp-content :global(a:hover) { color: var(--clr-primary-hover); text-decoration: underline; }
  .sp-content :global(img) { width: 100%; border-radius: var(--radius-card); margin: 1.75rem 0; }

  /* tabulka */
  .sp-content :global(table) {
    width: 100%; border-collapse: collapse;
    margin: 1.75rem 0; font-size: var(--font-size-small);
  }
  .sp-content :global(thead th) {
    background: var(--clr-primary-soft); color: var(--clr-heading);
    font-weight: 700; text-align: left;
    padding: .75rem 1rem;
    border-bottom: 2px solid var(--clr-primary);
  }
  .sp-content :global(tbody td) {
    padding: .75rem 1rem;
    border-bottom: 1px solid var(--clr-border);
  }
  .sp-content :global(tbody tr:nth-child(even)) { background: var(--clr-bg-alt); }

  /* ── NAVIGACE ── */
  .sp-nav {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1px; background: var(--clr-border);
  }
  .sp-nav-item {
    background: var(--clr-primary-soft); padding: 1.25rem 1.5rem;
    text-decoration: none; display: flex; flex-direction: column; gap: 6px;
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .sp-nav-item.prev { border-left: 4px solid var(--clr-primary); }
  .sp-nav-item.next { border-right: 4px solid var(--clr-primary); text-align: right; }
  .sp-nav-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0,0,0,.13);
  }
  .sp-nav-empty {
    pointer-events: none;
    background: var(--clr-bg-alt);
    border: none;
  }
  .sp-nav-empty:hover { transform: none; box-shadow: none; }
  .sp-nav-dir {
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--clr-primary);
    letter-spacing: .02em;
  }
  .sp-nav-title {
    font-family: var(--ff-head); font-size: var(--font-size-caption); font-weight: 700;
    color: var(--clr-heading); line-height: 1.3; transition: color .2s;
  }
  .sp-nav-item:hover .sp-nav-title { color: var(--clr-primary); }

  /* ── SIDEBAR (sticky) ── */
  .sp2-sidebar {
    position: sticky;
    top: calc(var(--nav-height, 72px) + 1rem);
    align-self: start;
    display: flex; flex-direction: column; gap: 1.25rem;
    padding-top: 1.75rem;
  }
  .bl-widget {
    background: #fff; border: 1px solid var(--clr-border);
    border-radius: var(--radius-card); padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,.07);
  }
  .bl-widget-title {
    font-family: var(--ff-head); font-size: var(--font-size-h5); font-weight: 700;
    color: var(--clr-primary); margin: 0 0 1rem;
  }

  /* kategorie */
  .bl-cat-widget-list { list-style: none; margin: 0; padding: 0; }
  .bl-cat-widget-item { border-bottom: 1px solid var(--clr-bg-alt); }
  .bl-cat-widget-item:last-child { border-bottom: none; }
  .bl-cat-link {
    display: flex; align-items: center; gap: 0;
    padding: .625rem 0; font-size: var(--font-size-caption); color: var(--clr-heading);
    font-weight: 500; text-decoration: none; transition: color .2s;
  }
  .bl-cat-arrow {
    display: inline-block; width: 0; overflow: hidden;
    color: var(--clr-primary); font-weight: 700; font-size: var(--font-size-caption);
    transition: width .2s ease; white-space: nowrap;
  }
  .bl-cat-name { flex: 1; transition: color .2s, padding-left .2s ease; }
  .bl-cat-count { font-size: var(--font-size-label); color: var(--clr-muted); flex-shrink: 0; }
  .bl-cat-link:hover .bl-cat-arrow { width: 18px; }
  .bl-cat-link:hover .bl-cat-name { color: var(--clr-primary); padding-left: 4px; }

  /* další příspěvky */
  .sp-recent-item {
    display: flex; gap: 12px; padding: .625rem 0;
    border-bottom: 1px solid var(--clr-bg-alt);
    text-decoration: none;
  }
  .sp-recent-item:last-child { border-bottom: none; }
  .sp-recent-thumb {
    width: 60px; height: 48px; border-radius: var(--radius-btn);
    flex-shrink: 0; background-color: var(--clr-primary-soft);
    background-position: center; background-size: cover;
  }
  .sp-recent-info { flex: 1; }
  .sp-recent-title {
    font-family: var(--ff-head); font-size: var(--font-size-meta); font-weight: 700;
    color: var(--clr-heading); line-height: 1.35; margin-bottom: 3px;
    transition: color .2s;
  }
  .sp-recent-item:hover .sp-recent-title { color: var(--clr-primary); }
  .sp-recent-date { font-size: var(--font-size-micro); color: var(--clr-muted); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .sp2-layout { grid-template-columns: 1fr; }
    .sp2-body-wrap { border-radius: 0; }
    .sp2-sidebar { position: static; padding-top: 1.75rem; }
  }
  @media (max-width: 600px) {
    .sp-section { padding: 1.5rem .75rem; }
    .sp-body { padding: 1.25rem; }
    .sp-nav { grid-template-columns: 1fr; }
    .sp2-hero { margin-left: -.75rem; padding: 2rem 0 1.75rem; }
    .sp-cover-full { margin-left: -.75rem; height: 220px; }
  }
</style>
