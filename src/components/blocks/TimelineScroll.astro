---
// TimelineScroll.astro — vertikální časová osa, která se ROZSVĚCUJE při scrollu.
// Progress linka roste shora dolů, body (tečky) i karty se postupně aktivují.
// Zdroj: Domov Turovice /nas-pribeh
//
// Props:
//   kicker, heading — nadpis sekce (volitelné)
//   items[] — { tag, title, text, highlight? }
//             highlight=true → zelený akcent místo primárního (poslední/cílový bod)
const { kicker, heading, items = [] } = Astro.props;
---
<section class="timeline-section">
  <div class="container">
    {(kicker || heading) && (
      <div class="section-heading">
        {kicker && <span class="section-label">{kicker}</span>}
        {heading && <h2>{heading}</h2>}
      </div>
    )}
    <div class="timeline" id="tlTrack">
      {items.map((it, i) => (
        <div class={`tl-item ${it.highlight ? 'tl-highlight' : ''}`} data-index={i}>
          <div class="tl-dot"></div>
          <div class="tl-content">
            {it.tag && <div class="tl-year-tag">{it.tag}</div>}
            <h3>{it.title}</h3>
            <p set:html={it.text} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline-section { padding: var(--space-12) 0; background: var(--color-bg); }
  .timeline { position: relative; max-width: 760px; margin: 0 auto; padding-left: 52px; }
  /* Šedý track přes celou výšku */
  .timeline::before {
    content: ''; position: absolute; left: 16px; top: 0; bottom: 0;
    width: 3px; background: var(--color-border); border-radius: 2px;
  }
  /* Barevná progress čára — výšku řídí JS přes --tl-progress */
  .timeline::after {
    content: ''; position: absolute; left: 16px; top: 0;
    width: 3px; height: var(--tl-progress, 0%);
    background: linear-gradient(to bottom, var(--color-primary) 0%, var(--color-accent) 100%);
    border-radius: 2px; transition: height .1s linear; z-index: 1;
  }
  .tl-item { display: flex; align-items: flex-start; gap: 28px; margin-bottom: 44px; position: relative; }
  .tl-item:last-child { margin-bottom: 0; }
  /* Tečka na čáře */
  .tl-dot {
    position: absolute; left: -44px; top: 24px;
    width: 16px; height: 16px; border-radius: 50%;
    background: var(--color-border); border: 3px solid var(--color-bg);
    z-index: 2; transition: background .4s, transform .4s, box-shadow .4s; flex-shrink: 0;
  }
  .tl-item.tl-active .tl-dot {
    background: var(--color-primary); transform: scale(1.3);
    box-shadow: 0 0 0 4px var(--color-primary-soft);
  }
  .tl-item.tl-highlight.tl-active .tl-dot {
    background: var(--color-accent);
    box-shadow: 0 0 0 5px var(--color-accent-light);
  }
  /* Karta — neaktivní je ztlumená, aktivní se rozsvítí */
  .tl-content {
    flex: 1; background: var(--color-white); border-radius: var(--radius-md);
    border: 1px solid var(--color-border); border-left: 3px solid var(--color-border);
    padding: 24px 28px; box-shadow: var(--shadow-card);
    transition: box-shadow .3s, transform .3s, border-left-color .4s, opacity .4s;
    opacity: .55; transform: translateX(10px);
  }
  .tl-item.tl-active .tl-content {
    opacity: 1; transform: translateX(0);
    border-left-color: var(--color-primary); box-shadow: var(--shadow-hover);
  }
  .tl-item.tl-highlight.tl-active .tl-content { border-left-color: var(--color-accent); }
  .tl-content:hover { box-shadow: var(--shadow-hover); transform: translateX(2px); }
  .tl-year-tag {
    display: inline-block; font-size: 11px; font-weight: 700;
    letter-spacing: .08em; text-transform: uppercase;
    color: var(--color-primary); background: var(--color-primary-soft);
    padding: 3px 10px; border-radius: 20px; margin-bottom: 10px;
  }
  .tl-item.tl-highlight .tl-year-tag { background: var(--color-accent-light); color: var(--color-accent); }
  .tl-content h3 { font-family: var(--font-serif); font-size: var(--text-xl); color: var(--color-primary); margin-bottom: 8px; line-height: 1.35; }
  .tl-content p { font-size: var(--text-body); color: var(--color-text); line-height: 1.65; margin: 0; }
  @media (max-width: 768px) {
    .timeline-section { padding: var(--space-8) 0; }
    .timeline { padding-left: 40px; }
    .timeline::before, .timeline::after { left: 12px; }
    .tl-dot { left: -34px; }
    .tl-content { padding: 20px; }
  }
</style>

<script>
  {
    const track = document.getElementById('tlTrack');
    if (track) {
      const items = Array.from(track.querySelectorAll('.tl-item'));
      function update() {
        const tr = track.getBoundingClientRect();
        const winH = window.innerHeight;
        const scrolled = winH * 0.65 - tr.top;
        const pct = Math.max(0, Math.min(100, (scrolled / tr.height) * 100));
        track.style.setProperty('--tl-progress', pct + '%');
        items.forEach((item) => {
          const rect = item.getBoundingClientRect();
          const dotY = rect.top + 28;
          item.classList.toggle('tl-active', dotY < winH * 0.72);
        });
      }
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update, { passive: true });
    }
  }
</script>
