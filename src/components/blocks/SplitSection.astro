---
// SplitSection.astro — text + obrázek vedle sebe
// Props: kicker, heading, paragraphs[], imageLabel, reverse, bg
const { kicker, heading, paragraphs = [], imageLabel = 'Fotografie', reverse = false, bg = 'white' } = Astro.props;
---
<section class={`split-section bg-${bg}`}>
  <div class="container">
    <div class={`split ${reverse ? 'split--reverse' : ''}`}>
      <div>
        {kicker && <span class="section-label">{kicker}</span>}
        <h2 set:html={heading} />
        {paragraphs.map((p) => <p set:html={p} />)}
      </div>
      <div class="split__img-placeholder">
        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        <p set:html={imageLabel} />
      </div>
    </div>
  </div>
</section>
