---
// SplitSection.astro — text + obrázek vedle sebe
// Props: kicker/label, heading, paragraphs[]/text, imageLabel/imageAlt, image, reverse/imagePosition, bg, link
const {
  kicker, label,
  heading,
  paragraphs = [], text,
  imageLabel = 'Fotografie', imageAlt,
  image,
  reverse = false, imagePosition,
  bg = 'white',
  link,
} = Astro.props;

const _label = label ?? kicker;
const _reverse = imagePosition ? imagePosition === 'left' : reverse;
const _paragraphs = text ? text.split('\n\n') : paragraphs;
---
<section class={`split-section bg-${bg}`}>
  <div class="container">
    <div class={`split ${_reverse ? 'split--reverse' : ''}`}>
      <div>
        {_label && <span class="section-label">{_label}</span>}
        <h2 set:html={heading} />
        {_paragraphs.map((p) =>
          p.startsWith('„')
            ? <blockquote set:html={p} />
            : <p set:html={p} />
        )}
        {link && <a href={link.href} class="btn btn-secondary">{link.text}<i class="ti ti-arrow-right"></i></a>}
      </div>
      {image ? (
        <div class="split__img">
          <img src={image} alt={imageAlt ?? imageLabel} loading="lazy" />
        </div>
      ) : (
        <div class="split__img-placeholder">
          <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <p set:html={imageAlt ?? imageLabel} />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  blockquote {
    border-left: 4px solid var(--color-primary);
    margin: 1.5rem 0;
    padding: 0.5rem 0 0.5rem 1.25rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--color-text);
    line-height: 1.7;
  }
</style>
