---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'clanky'>[];
  limit?: number;
  columns?: 2 | 3;
  filterCategory?: string;
  showFilter?: boolean;
}

const {
  posts: rawPosts,
  limit,
  columns = 3,
  filterCategory,
  showFilter = false,
} = Astro.props;

let posts = filterCategory
  ? rawPosts.filter(p => p.data.kategorie === filterCategory)
  : rawPosts;

if (limit) posts = posts.slice(0, limit);

const categories = showFilter
  ? ['Vše', ...Array.from(new Set(rawPosts.map(p => p.data.kategorie)))]
  : [];

function formatDate(date: Date): string {
  return date.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

{showFilter && (
  <div class="section-filter" id="filterBar">
    {categories.map(cat => (
      <button class={`filter-btn${cat === 'Vše' ? ' active' : ''}`} data-cat={cat}>{cat}</button>
    ))}
  </div>
)}

<div
  class="news-grid"
  id="newsGrid"
  style={`grid-template-columns: repeat(${columns}, 1fr);`}
>
  {posts.length === 0 && (
    <div class="no-posts"><p>Zatím žádné příspěvky.</p></div>
  )}
  {posts.map(post => (
    <article class="news-card" data-kategorie={post.data.kategorie}>
      {post.data.nahled
        ? <img class="news-card-img" src={post.data.nahled} alt={post.data.titulek} loading="lazy" />
        : (
          <div class="news-card-img-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
        )
      }
      <div class="news-card-body">
        <div class="news-card-meta">
          <span class="news-card-tag">{post.data.kategorie}</span>
          <span class="news-card-date">{formatDate(post.data.datum)}</span>
        </div>
        <h2>{post.data.titulek}</h2>
        <p>{post.data.perex}</p>
        <a href={`/${post.slug}`} class="news-card-link">
          Číst dál
          <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </article>
  ))}
</div>

{showFilter && (
  <script>
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('#filterBar .filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('#newsGrid .news-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.dataset.cat;
        cards.forEach(card => {
          const match = cat === 'Vše' || card.dataset.kategorie === cat;
          card.style.display = match ? '' : 'none';
        });
      });
    });
  </script>
)}

<style>
/* filter */
.section-filter {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 40px;
}
.filter-btn {
  padding: 8px 18px;
  border-radius: 20px;
  border: 1.5px solid var(--clr-border);
  background: #fff;
  color: var(--clr-text);
  font-family: var(--ff-body);
  font-size: var(--font-size-caption);
  font-weight: 500;
  cursor: pointer;
  transition: all .18s;
}
.filter-btn:hover,
.filter-btn.active {
  background: var(--clr-primary);
  border-color: var(--clr-primary);
  color: #fff;
}

/* grid */
.news-grid {
  display: grid;
  gap: 28px;
  margin-bottom: 48px;
}

/* card */
.news-card {
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
  border: 1.5px solid var(--clr-border);
  display: flex;
  flex-direction: column;
  transition: box-shadow .2s, transform .2s;
}
.news-card:hover {
  box-shadow: 0 8px 28px rgba(0,0,0,.1);
  transform: translateY(-3px);
}
.news-card-img {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  display: block;
}
.news-card-img-placeholder {
  width: 100%;
  aspect-ratio: 16/9;
  background: var(--clr-bg-alt);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--clr-muted);
}
.news-card-img-placeholder svg {
  width: 48px; height: 48px;
  stroke: var(--clr-border);
}
.news-card-body {
  padding: 22px 24px 24px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.news-card-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
}
.news-card-tag {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: var(--font-size-label);
  font-weight: 700;
  background: rgba(155,66,73,.12);
  color: var(--clr-primary);
  letter-spacing: .04em;
}
.news-card-date {
  font-size: var(--font-size-meta);
  color: var(--clr-muted);
}
.news-card-body h2 {
  font-family: var(--ff-head);
  font-size: var(--font-size-perex);
  font-weight: 700;
  color: var(--clr-heading);
  line-height: 1.35;
  margin: 0 0 10px;
}
.news-card-body p {
  font-size: var(--font-size-caption);
  line-height: 1.65;
  color: var(--clr-text);
  margin: 0 0 16px;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.news-card-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: var(--font-size-caption);
  font-weight: 700;
  color: var(--clr-primary);
  text-decoration: none;
  margin-top: auto;
  transition: gap .2s;
}
.news-card-link:hover { gap: 10px; }
.news-card-link svg {
  width: 16px; height: 16px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* no posts */
.no-posts {
  grid-column: 1 / -1;
  text-align: center;
  padding: 48px;
  color: var(--clr-muted);
}

/* responsive */
@media (max-width: 1024px) {
  .news-grid { grid-template-columns: repeat(2, 1fr) !important; }
}
@media (max-width: 640px) {
  .news-grid { grid-template-columns: 1fr !important; }
}
</style>
