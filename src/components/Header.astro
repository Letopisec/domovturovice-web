---
const navItems = [
  {
    label: 'O nás',
    href: '#',
    sub: [
      { label: 'Náš příběh', href: '#' },
      { label: 'Náš tým', href: '#' },
      { label: 'Prostory a zázemí', href: '#' },
    ],
  },
  {
    label: 'Péče a služby',
    href: '#',
    sub: [
      { label: 'Jak pečujeme', href: '/jak-pecujeme' },
      { label: 'Aktivizace a volný čas', href: '#' },
      { label: 'Stravování', href: '#' },
    ],
  },
  {
    label: 'Přijetí do domova',
    href: '#',
    sub: [
      { label: 'Jak probíhá přijetí', href: '/prijeti' },
      { label: 'Ceník', href: '/cenik' },
      { label: 'Dokumenty ke stažení', href: '/dokumenty' },
      { label: 'Časté otázky', href: '/faq' },
    ],
  },
  { label: 'Aktuality', href: '/aktuality' },
  { label: 'Kontakt', href: '/kontakt' },
];
---

<nav class="nav" id="mainNav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img class="nav-logo-img" src="/images/logo.svg" alt="Domov Turovice logo">
      <div class="nav-logo-text">
        <strong>Domov Turovice</strong>
        <small>zapsaný ústav</small>
      </div>
    </a>

    <ul class="nav-menu">
      {navItems.map((item) => (
        <li class={`nav-item${item.sub ? ' has-sub' : ''}`}>
          <a href={item.href}>{item.label}</a>
          {item.sub && (
            <div class="nav-dropdown">
              {item.sub.map((sub) => (
                <a href={sub.href}>{sub.label}</a>
              ))}
            </div>
          )}
        </li>
      ))}
    </ul>

    <a href="tel:+420724211589" class="nav-phone-btn">
      <svg viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
      +420 724 211 589
    </a>

    <button class="hamburger" id="hamburger" aria-label="Otevřít menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <div class="mobile-group-title">O nás</div>
  <a href="#">Náš příběh</a>
  <a href="#">Náš tým</a>
  <a href="#">Prostory a zázemí</a>
  <div class="mobile-group-title">Péče a služby</div>
  <a href="/jak-pecujeme">Jak pečujeme</a>
  <a href="#">Aktivizace a volný čas</a>
  <a href="#">Stravování</a>
  <div class="mobile-group-title">Přijetí do domova</div>
  <a href="/prijeti">Jak probíhá přijetí</a>
  <a href="/cenik">Ceník</a>
  <a href="/dokumenty">Dokumenty ke stažení</a>
  <a href="/faq">Časté otázky</a>
  <div class="mobile-group-title">Ostatní</div>
  <a href="/aktuality">Aktuality</a>
  <a href="#">Kariéra</a>
  <a href="#">Pro rodiny</a>
  <a href="/kontakt">Kontakt</a>
  <a href="tel:+420724211589" style="color:var(--clr-primary);font-weight:600">+420 724 211 589</a>
</div>

<script>
  const nav = document.getElementById('mainNav');
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');

  // Scroll shadow
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 10);
  });

  // Hamburger
  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('active');
    mobileMenu?.classList.toggle('open');
  });

  // Dropdown – click to open (UX pro seniory)
  document.querySelectorAll('.nav-item.has-sub').forEach((item) => {
    item.querySelector('a')?.addEventListener('click', (e) => {
      e.preventDefault();
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.nav-item.has-sub').forEach((i) => i.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    });
  });

  // Zavřít dropdown kliknutím mimo
  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.nav-item.has-sub')) {
      document.querySelectorAll('.nav-item.has-sub').forEach((i) => i.classList.remove('open'));
    }
  });
</script>
