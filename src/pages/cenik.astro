<script>
  document.getElementById('pnpTabNav')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.tab2-btn') as HTMLElement;
    if (!btn) return;
    const tabId = btn.dataset.tab;
    document.querySelectorAll('.tab2-btn').forEach((b) => b.classList.remove('active'));
    document.querySelectorAll('.tab2-body').forEach((b) => b.classList.remove('active'));
    btn.classList.add('active');
    if (tabId) document.getElementById(tabId)?.classList.add('active');
  });
</script>
