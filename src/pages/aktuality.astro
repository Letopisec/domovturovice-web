---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.datum.valueOf() - a.data.datum.valueOf());

const categories = ['Vše', ...Array.from(new Set(posts.map(p => p.data.kategorie)))];

function formatDate(date: Date): string {
  return date.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Layout
  title="Aktuality | Domov Turovice"
  description="Zprávy o životě v Domově Turovice — aktivizace, péče, slavnosti i každodenní radosti. Sledujte, co se u nás děje."
>

<style>
/* ── PAGE HERO ── */
.page-hero {
  background: linear-gradient(135deg, var(--clr-primary) 0%, #7a3238 100%);
  color: #fff;
  padding: 72px 0 56px;
  position: relative;
  overflow: hidden;
}
.page-hero::after {
  content: '';
  position: absolute;
  right: -80px; top: -80px;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: rgba(255,255,255,.06);
  pointer-events: none;
}
.page-hero-inner { position: relative; z-index: 2; max-width: 680px; }
.label {
  display: inline-block;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(255,255,255,.7);
  margin-bottom: 14px;
}
.page-hero h1 {
  font-family: var(--ff-head);
  font-size: clamp(1.9rem, 4vw, 2.7rem);
  font-weight: 700;
  color: #fff;
  margin: 0 0 18px;
  line-height: 1.2;
}
.perex {
  font-size: 1.05rem;
  line-height: 1.65;
  color: rgba(255,255,255,.85);
  margin: 0;
}

/* ── BLOG SECTION ── */
.blog-section {
  padding: 64px 0 80px;
  background: var(--clr-bg);
}

/* filter */
.section-filter {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 40px;
}
.filter-btn {
  padding: 8px 18px;
  border-radius: 20px;
  border: 1.5px solid var(--clr-border);
  background: #fff;
  color: var(--clr-text);
  font-family: var(--ff-body);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all .18s;
}
.filter-btn:hover,
.filter-btn.active {
  background: var(--clr-primary);
  border-color: var(--clr-primary);
  color: #fff;
}

/* grid */
.news-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  margin-bottom: 48px;
}

/* card */
.news-card {
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
  border: 1.5px solid var(--clr-border);
  display: flex;
  flex-direction: column;
  transition: box-shadow .2s, transform .2s;
}
.news-card:hover {
  box-shadow: 0 8px 28px rgba(0,0,0,.1);
  transform: translateY(-3px);
}
.news-card-img {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  display: block;
}
.news-card-img-placeholder {
  width: 100%;
  aspect-ratio: 16/9;
  background: var(--clr-bg-alt);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--clr-muted);
}
.news-card-img-placeholder svg {
  width: 48px; height: 48px;
  stroke: var(--clr-border);
}
.news-card-body {
  padding: 22px 24px 24px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.news-card-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
}
.news-card-tag {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 700;
  background: rgba(155,66,73,.12);
  color: var(--clr-primary);
  letter-spacing: .04em;
}
.news-card-tag.green { background: rgba(89,152,108,.12); color: var(--clr-green); }
.news-card-tag.orange { background: rgba(218,136,65,.12); color: var(--clr-orange); }
.news-card-tag.blue { background: rgba(75,119,171,.12); color: var(--clr-blue); }
.news-card-date {
  font-size: 13px;
  color: var(--clr-muted);
}
.news-card-body h2 {
  font-family: var(--ff-head);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--clr-heading);
  line-height: 1.35;
  margin: 0 0 10px;
}
.news-card-body p {
  font-size: 14px;
  line-height: 1.65;
  color: var(--clr-text);
  margin: 0 0 16px;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.news-card-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 14px;
  font-weight: 700;
  color: var(--clr-primary);
  text-decoration: none;
  margin-top: auto;
  transition: gap .2s;
}
.news-card-link:hover { gap: 10px; }
.news-card-link svg {
  width: 16px; height: 16px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* no posts */
.no-posts {
  grid-column: 1 / -1;
  text-align: center;
  padding: 48px;
  color: var(--clr-muted);
}

/* pagination */
.pagination {
  display: flex;
  justify-content: center;
  gap: 8px;
}
.pag-btn {
  min-width: 40px; height: 40px;
  border-radius: 8px;
  border: 1.5px solid var(--clr-border);
  background: #fff;
  color: var(--clr-text);
  font-size: 14px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  cursor: pointer;
  transition: all .18s;
}
.pag-btn:hover, .pag-btn.active {
  background: var(--clr-primary);
  border-color: var(--clr-primary);
  color: #fff;
}
.pag-btn.arrow { padding: 0 10px; }
.pag-btn svg {
  width: 16px; height: 16px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* ── CTA ── */
.cta-section {
  padding: 72px 0;
  background: linear-gradient(135deg, var(--clr-primary) 0%, #7a3238 100%);
}
.cta-inner {
  text-align: center;
  max-width: 580px;
  margin: 0 auto;
  color: #fff;
}
.cta-inner h2 {
  font-family: var(--ff-head);
  font-size: clamp(1.7rem, 3vw, 2.2rem);
  font-weight: 700;
  color: #fff;
  margin: 0 0 14px;
}
.cta-inner p {
  font-size: 1.05rem;
  line-height: 1.65;
  color: rgba(255,255,255,.85);
  margin: 0 0 32px;
}
.cta-buttons { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
.cta-buttons .btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 13px 24px;
  border-radius: 8px;
  font-weight: 600;
  font-size: 15px;
  text-decoration: none;
  transition: all .2s;
}
.btn-primary { background: #fff; color: var(--clr-primary); border: 2px solid #fff; }
.btn-primary:hover { background: transparent; color: #fff; }
.btn-secondary { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.6); }
.btn-secondary:hover { border-color: #fff; background: rgba(255,255,255,.12); }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) { .news-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px) {
  .news-grid { grid-template-columns: 1fr; }
  .blog-section { padding: 44px 0 56px; }
  .page-hero { padding: 52px 0 40px; }
}
</style>

<!-- ══ PAGE HERO ══ -->
<section class="page-hero">
  <div class="container">
    <div class="page-hero-inner">
      <span class="label">Domov Turovice</span>
      <h1>Aktuality z domova pro seniory</h1>
      <p class="perex">Přinášíme zprávy o životě v Domově Turovice — o aktivizaci, péči, slavnostech i každodenních radostech. Sledujte, co se u nás děje.</p>
    </div>
  </div>
</section>

<!-- ══ BLOG GRID ══ -->
<section class="blog-section">
  <div class="container">

    <div class="section-filter" id="filterBar">
      {categories.map(cat => (
        <button class={`filter-btn${cat === 'Vše' ? ' active' : ''}`} data-cat={cat}>{cat}</button>
      ))}
    </div>

    <div class="news-grid" id="newsGrid">
      {posts.length === 0 && (
        <div class="no-posts"><p>Zatím žádné příspěvky.</p></div>
      )}
      {posts.map(post => (
        <article class="news-card" data-kategorie={post.data.kategorie}>
          {post.data.nahledovyObrazek
            ? <img class="news-card-img" src={post.data.nahledovyObrazek} alt={post.data.titulek} loading="lazy" />
            : (
              <div class="news-card-img-placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
            )
          }
          <div class="news-card-body">
            <div class="news-card-meta">
              <span class="news-card-tag">{post.data.kategorie}</span>
              <span class="news-card-date">{formatDate(post.data.datum)}</span>
            </div>
            <h2>{post.data.titulek}</h2>
            <p>{post.data.perex}</p>
            <a href={`/${post.slug}`} class="news-card-link">
              Číst dál
              <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<!-- ══ CTA ══ -->
<section class="cta-section">
  <div class="container">
    <div class="cta-inner">
      <h2>Máte zájem o pobyt v Domově Turovice?</h2>
      <p>Rádi vás přivítáme. Zavolejte nám nebo pošlete žádost o přijetí. Odpovíme do 24 hodin.</p>
      <div class="cta-buttons">
        <a href="/prijeti" class="btn btn-primary">Jak probíhá přijetí</a>
        <a href="/kontakt" class="btn btn-secondary">Napište nám</a>
      </div>
    </div>
  </div>
</section>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.news-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = btn.dataset.cat;
      cards.forEach(card => {
        const match = cat === 'Vše' || card.dataset.kategorie === cat;
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>

</Layout>
