---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../utils/slug';

const allPosts = await getCollection('clanky');
const posts = allPosts.sort((a, b) => b.data.datum.valueOf() - a.data.datum.valueOf());

const categories = ['Vše', ...Array.from(new Set(posts.map(p => p.data.kategorie)))];

function formatDate(date: Date): string {
  return date.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Layout
  title="Aktuality | Domov Turovice"
  description="Zprávy o životě v Domově Turovice — aktivizace, péče, slavnosti i každodenní radosti. Sledujte, co se u nás děje."
>

<style>
/* ── PAGE HERO ── */
.page-hero {
  background: linear-gradient(135deg, var(--clr-primary) 0%, #7a3238 100%);
  color: #fff;
  padding: 72px 0 56px;
  position: relative;
  overflow: hidden;
}
.page-hero::after {
  content: '';
  position: absolute;
  right: -80px; top: -80px;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: rgba(255,255,255,.06);
  pointer-events: none;
}
.page-hero-inner { position: relative; z-index: 2; max-width: 680px; }
.label {
  display: inline-block;
  font-size: var(--font-size-label);
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(255,255,255,.7);
  margin-bottom: 14px;
}
.page-hero h1 {
  font-family: var(--ff-head);
  font-size: clamp(1.9rem, 4vw, 2.7rem);
  font-weight: 700;
  color: #fff;
  margin: 0 0 18px;
  line-height: 1.2;
}
.perex {
  font-size: var(--font-size-perex);
  line-height: 1.65;
  color: rgba(255,255,255,.85);
  margin: 0;
}

/* ── BLOG SECTION ── */
.blog-section {
  padding: 64px 0 80px;
  background: var(--clr-bg);
}

/* filter */
.section-filter {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 40px;
}
.filter-btn {
  padding: 8px 18px;
  border-radius: 20px;
  border: 1.5px solid var(--clr-border);
  background: #fff;
  color: var(--clr-text);
  font-family: var(--ff-body);
  font-size: var(--font-size-caption);
  font-weight: 500;
  cursor: pointer;
  transition: all .18s;
}
.filter-btn:hover,
.filter-btn.active {
  background: var(--clr-primary);
  border-color: var(--clr-primary);
  color: #fff;
}

/* grid */
.news-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  margin-bottom: 48px;
}

/* card */
.news-card {
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
  border: 1.5px solid var(--clr-border);
  display: flex;
  flex-direction: column;
  transition: box-shadow .2s, transform .2s;
}
.news-card:hover {
  box-shadow: 0 8px 28px rgba(0,0,0,.1);
  transform: translateY(-3px);
}
.news-card-img {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  display: block;
}
.news-card-img-placeholder {
  width: 100%;
  aspect-ratio: 16/9;
  background: var(--clr-bg-alt);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--clr-muted);
}
.news-card-img-placeholder svg {
  width: 48px; height: 48px;
  stroke: var(--clr-border);
}
.news-card-body {
  padding: 22px 24px 24px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.news-card-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
}
.news-card-tag {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: var(--font-size-label);
  font-weight: 700;
  background: rgba(155,66,73,.12);
  color: var(--clr-primary);
  letter-spacing: .04em;
  text-decoration: none;
  cursor: pointer;
  transition: opacity .2s;
  position: relative;
  z-index: 2;
}
.news-card-tag:hover { opacity: .75; }
.news-card-tag.green { background: rgba(89,152,108,.12); color: var(--clr-green); }
.news-card-tag.orange { background: rgba(218,136,65,.12); color: var(--clr-orange); }
.news-card-tag.blue { background: rgba(75,119,171,.12); color: var(--clr-blue); }
.news-card-date {
  font-size: var(--font-size-meta);
  color: var(--clr-muted);
}
.news-card-body h2 {
  font-family: var(--ff-head);
  font-size: var(--font-size-perex);
  font-weight: 700;
  color: var(--clr-heading);
  line-height: 1.35;
  margin: 0 0 10px;
}
.news-card-body p {
  font-size: var(--font-size-caption);
  line-height: 1.65;
  color: var(--clr-text);
  margin: 0 0 16px;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.news-card-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: var(--font-size-caption);
  font-weight: 700;
  color: var(--clr-primary);
  text-decoration: none;
  margin-top: auto;
  transition: gap .2s;
}
.news-card-link:hover { gap: 10px; }
.news-card-link svg {
  width: 16px; height: 16px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* proklikatelná celá karta */
.news-card { position: relative; }
.news-card-cover-link {
  position: absolute;
  inset: 0;
  z-index: 1;
}
.news-card-meta { position: relative; z-index: 2; }
.news-card-link {
  position: relative;
  z-index: 2;
}

/* no posts */
.no-posts {
  grid-column: 1 / -1;
  text-align: center;
  padding: 48px;
  color: var(--clr-muted);
}

/* pagination */
.pagination {
  display: flex;
  justify-content: center;
  gap: 8px;
}
.pag-btn {
  min-width: 40px; height: 40px;
  border-radius: 8px;
  border: 1.5px solid var(--clr-border);
  background: #fff;
  color: var(--clr-text);
  font-size: var(--font-size-caption);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  cursor: pointer;
  transition: all .18s;
}
.pag-btn:hover, .pag-btn.active {
  background: var(--clr-primary);
  border-color: var(--clr-primary);
  color: #fff;
}
.pag-btn.arrow { padding: 0 10px; }
.pag-btn svg {
  width: 16px; height: 16px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* ── CTA ── */
.cta-section {
  padding: 72px 0;
  background: #EDE8E3;
}
.cta-inner {
  text-align: center;
  max-width: 580px;
  margin: 0 auto;
  color: var(--clr-primary);
}
.cta-inner h2 {
  font-family: var(--ff-head);
  font-size: clamp(1.7rem, 3vw, 2.2rem);
  font-weight: 700;
  color: var(--clr-primary);
  margin: 0 0 14px;
}
.cta-inner p {
  font-size: var(--font-size-perex);
  line-height: 1.65;
  color: var(--clr-text-body);
  margin: 0 0 32px;
}
.cta-buttons { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
.cta-buttons .btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 13px 24px;
  border-radius: 8px;
  font-weight: 600;
  font-size: var(--font-size-ui);
  text-decoration: none;
  transition: all .2s;
}
.btn-primary { background: #fff; color: var(--clr-primary); border: 2px solid #fff; }
.btn-primary:hover { background: transparent; color: #fff; }
.btn-secondary { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.6); }
.btn-secondary:hover { border-color: #fff; background: rgba(255,255,255,.12); }

/* ── RESPONSIVE ── */
@media (max-width: 1024px) { .news-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px) {
  .news-grid { grid-template-columns: 1fr; }
  .blog-section { padding: 44px 0 56px; }
  .page-hero { padding: 52px 0 40px; }
}

.related-links { padding: 56px 0; background: var(--clr-bg); }
.related-links h2 {
  font-family: var(--ff-head);
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--clr-heading);
  margin: 0 0 24px;
}
.related-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}
.related-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px 18px;
  background: #fff;
  border: 1.5px solid var(--clr-border);
  border-radius: 10px;
  text-decoration: none;
  color: var(--clr-heading);
  font-weight: 600;
  font-size: var(--font-size-ui);
  transition: all .2s;
}
.related-item:hover { border-color: var(--clr-primary); color: var(--clr-primary); box-shadow: 0 4px 14px rgba(155,66,73,.1); }
.related-item svg {
  width: 20px; height: 20px;
  stroke: var(--clr-primary);
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  flex-shrink: 0;
}
@media (max-width: 768px) { .related-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px) { .related-grid { grid-template-columns: 1fr; } }

</style>

<!-- ══ PAGE HERO ══ -->
<section class="page-hero">
  <div class="container">
    <div class="page-hero-inner">
      <span class="label">Domov Turovice</span>
      <h1>Aktuality z domova pro seniory</h1>
      <p class="perex">Přinášíme zprávy o životě v Domově Turovice — o aktivizaci, péči, slavnostech i každodenních radostech. Sledujte, co se u nás děje.</p>
    </div>
  </div>
</section>

<!-- ══ BLOG GRID ══ -->
<section class="blog-section">
  <div class="container">

    <div class="section-filter">
      <a href="/aktuality" class="filter-btn active">Vše</a>
      {categories.filter(cat => cat !== 'Vše').map(cat => (
        <a href={`/${slugify(cat)}`} class="filter-btn">{cat}</a>
      ))}
    </div>

    <div class="news-grid">
      {posts.length === 0 && (
        <div class="no-posts"><p>Zatím žádné příspěvky.</p></div>
      )}
      {posts.map(post => (
        <article class="news-card" data-kategorie={post.data.kategorie}>
          <a href={`/${post.slug}`} class="news-card-cover-link" aria-label={post.data.titulek} tabindex="-1"></a>
          {post.data.nahled
            ? <img class="news-card-img" src={post.data.nahled} alt={post.data.titulek} loading="lazy" />
            : (
              <div class="news-card-img-placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
            )
          }
          <div class="news-card-body">
            <div class="news-card-meta">
              <a href={`/${slugify(post.data.kategorie)}`} class="news-card-tag">{post.data.kategorie}</a>
              <span class="news-card-date">{formatDate(post.data.datum)}</span>
            </div>
            <h2>{post.data.titulek}</h2>
            <p>{post.data.perex}</p>
            <a href={`/${post.slug}`} class="news-card-link">
              Číst dál
              <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<!-- ══ CTA ══ -->
<section class="cta-section has-circles">
  <div class="container">
    <div class="cta-inner">
      <h2>Máte zájem o pobyt v Domově Turovice?</h2>
      <p>Rádi vás přivítáme. Zavolejte nám nebo pošlete žádost o přijetí. Odpovíme do 24 hodin.</p>
      <div class="cta-buttons">
        <a href="/prijeti" class="btn btn-primary">Jak probíhá přijetí</a>
        <a href="/kontakt" class="btn btn-secondary">Napište nám</a>
      </div>
    </div>
  </div>
</section>

<!-- RELATED LINKS -->
<div class="related-links">
  <div class="container">
    <h2>Mohlo by vás zajímat</h2>
    <nav class="related-grid" aria-label="Související stránky">
      <a href="/jak-pecujeme" class="related-item">
        <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        Jak pečujeme
      </a>
      <a href="/nas-pribeh" class="related-item">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Náš příběh
      </a>
      <a href="/prijeti" class="related-item">
        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        Jak probíhá přijetí
      </a>
      <a href="/cenik" class="related-item">
        <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        Ceník
      </a>
    </nav>
  </div>
</div>

</Layout>
