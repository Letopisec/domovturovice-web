---
// ════════════════════════════════════════════════════════════════
// PLOCHÁ DYNAMICKÁ ROUTA — vše na domena.cz/[slug]
//   1. ČLÁNEK     → SinglePost (Molti varianta 2)
//   2. KATEGORIE  → rozcestník článků kategorie
//   3. ŠTÍTEK     → rozcestník článků se štítkem
// ════════════════════════════════════════════════════════════════
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SinglePost from '../components/blocks/SinglePost.astro';
import BlogGrid from '../components/blocks/BlogGrid.astro';
import { slugify } from '../utils/slug';

// Perex pro každou kategorii — SEO text v hero rozcestníku
const kategoriePerexy: Record<string, string> = {
  'Průvodce pro rodiny': 'Praktické rady pro rodiny, které hledají domov pro seniory. Jak vybrat správné zařízení, co sledovat při návštěvě a jak zvládnout náročné rozhodnutí.',
  'Finance a přijetí': 'Informace o příspěvku na péči, cenách ubytování a průběhu přijetí do domova pro seniory. Vše, co potřebujete vědět před podáním žádosti.',
  'Pro rodiny': 'Jak zůstat v kontaktu s blízkým v domově pro seniory, jak probíhají návštěvy a jak rodina může podpořit adaptaci klienta.',
  'Péče a aktivizace': 'Ošetřovatelská péče, aktivizační programy a každodenní život v Domově Turovice. Canisterapie, muzikoterapie, ergoterapie a další aktivity pro seniory.',
};

function fmt(d: Date): string {
  return d.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}

export async function getStaticPaths() {
  const clanky = await getCollection('clanky');

  // řazení nejnovější první (pro navigaci a "další příspěvky")
  const serazene = [...clanky].sort((a, b) => b.data.datum.valueOf() - a.data.datum.valueOf());

  // 1) Cesty článků
  const clanekPaths = serazene.map((clanek, i) => ({
    params: { slug: clanek.slug },
    props: {
      type: 'clanek',
      clanek,
      // navigace: novější = prev (vlevo), starší = next (vpravo)
      prev: serazene[i - 1] ? { titulek: serazene[i - 1].data.titulek, slug: serazene[i - 1].slug } : null,
      next: serazene[i + 1] ? { titulek: serazene[i + 1].data.titulek, slug: serazene[i + 1].slug } : null,
    },
  }));

  // 2) Cesty kategorií (unikátní)
  const kategorie = [...new Set(clanky.map((c) => c.data.kategorie))];
  const kategoriePaths = kategorie.map((kat) => ({
    params: { slug: slugify(kat) },
    props: {
      type: 'kategorie',
      nazev: kat,
      clanky: clanky.filter((c) => c.data.kategorie === kat),
      vsechnyClanky: clanky,
    },
  }));

  // 3) Cesty štítků (unikátní)
  const stitky = [...new Set(clanky.flatMap((c) => c.data.stitky))];
  const stitkyPaths = stitky.map((tag) => ({
    params: { slug: slugify(tag) },
    props: {
      type: 'stitek',
      nazev: tag,
      clanky: clanky.filter((c) => c.data.stitky.includes(tag)),
    },
  }));

  // KONTROLA KOLIZÍ
  const all = [...clanekPaths, ...kategoriePaths, ...stitkyPaths];
  const seen = new Set();
  for (const p of all) {
    if (seen.has(p.params.slug)) {
      throw new Error(`KOLIZE SLUGU: "${p.params.slug}" existuje víckrát. Přejmenuj článek/kategorii/štítek.`);
    }
    seen.add(p.params.slug);
  }

  return all;
}

const { type } = Astro.props;

// ── ČLÁNEK ──
let Content, d, prev, next, kategorieList: any[] = [], dalsiClanky: any[] = [], stitkySlugy: any[] = [];
if (type === 'clanek') {
  const rendered = await Astro.props.clanek.render();
  Content = rendered.Content;
  d = Astro.props.clanek.data;
  prev = Astro.props.prev;
  next = Astro.props.next;

  const vsechny = await getCollection('clanky');

  // počty článků v kategoriích (do sidebaru)
  const pocty: Record<string, number> = {};
  vsechny.forEach((c) => { pocty[c.data.kategorie] = (pocty[c.data.kategorie] || 0) + 1; });
  kategorieList = Object.entries(pocty).map(([nazev, pocet]) => ({
    nazev, slug: slugify(nazev), pocet,
  }));

  // další příspěvky (3 nejnovější kromě aktuálního)
  dalsiClanky = vsechny
    .filter((c) => c.slug !== Astro.props.clanek.slug)
    .sort((a, b) => b.data.datum.valueOf() - a.data.datum.valueOf())
    .slice(0, 3)
    .map((c) => ({ titulek: c.data.titulek, slug: c.slug, datum: c.data.datum, nahled: c.data.nahled }));

  // štítky s odkazy
  stitkySlugy = d.stitky.map((t: string) => ({ nazev: t, slug: slugify(t) }));
}

// ── ROZCESTNÍK ──
const { nazev, clanky: vypisClanky, vsechnyClanky } = Astro.props;

// kategorie pro filtrační lištu (všechny unikátní z celé kolekce)
const vsechnyKategorie = type !== 'clanek'
  ? ['Vše', ...Array.from(new Set((vsechnyClanky || []).map((c: any) => c.data.kategorie)))]
  : [];

const katPerex = nazev && kategoriePerexy[nazev]
  ? kategoriePerexy[nazev]
  : `Články v kategorii ${nazev}.`;

const schema = type === 'clanek'
  ? { '@type': 'Article', headline: d.titulek, datePublished: d.datum.toISOString(), author: { '@type': 'Person', name: d.autor }, articleSection: d.kategorie }
  : { '@type': 'CollectionPage', name: nazev };

const pageTitle = type === 'clanek' ? `${d.titulek}` : `${nazev} – články`;
const pageDesc = type === 'clanek' ? (d.popis || d.perex) : `Články v kategorii ${nazev}.`;
---
<Layout title={pageTitle} description={pageDesc} schema={schema}>
  {type === 'clanek' ? (
    <SinglePost
      titulek={d.titulek}
      datum={d.datum}
      kategorie={d.kategorie}
      katSlug={slugify(d.kategorie)}
      stitkySlugy={stitkySlugy}
      nahled={d.nahled}
      autor={d.autor}
      zdroj={d.zdroj}
      kategorieList={kategorieList}
      dalsiClanky={dalsiClanky}
      prev={prev}
      next={next}
    >
      <Content />
    </SinglePost>
  ) : (
    <>
      <!-- HERO -->
      <section class="kat-hero">
        <div class="container">
          <div class="kat-hero-inner">
            <span class="label">{type === 'kategorie' ? 'Kategorie' : 'Štítek'}</span>
            <h1>{nazev} — všechny informace</h1>
            <p class="perex">{katPerex}</p>
          </div>
        </div>
      </section>

      <!-- VÝPIS -->
      <section class="kat-body">
        <div class="container">

          <!-- filtrační lišta: aktivní = aktuální kategorie, ostatní = odkaz -->
          <div class="section-filter">
            {vsechnyKategorie.map(cat => (
              cat === nazev
                ? <span class="filter-btn active">{cat}</span>
                : cat === 'Vše'
                  ? <a href="/aktuality" class="filter-btn">Vše</a>
                  : <a href={`/${slugify(cat)}`} class="filter-btn">{cat}</a>
            ))}
          </div>

          <!-- grid článků -->
          <div class="news-grid">
            {vypisClanky
              .sort((a: any, b: any) => b.data.datum.valueOf() - a.data.datum.valueOf())
              .map((post: any) => (
              <article class="news-card" data-kategorie={post.data.kategorie}>
                <a href={`/${post.slug}`} class="news-card-cover-link" aria-label={post.data.titulek} tabindex="-1"></a>
                {post.data.nahled
                  ? <img class="news-card-img" src={post.data.nahled} alt={post.data.titulek} loading="lazy" />
                  : (
                    <div class="news-card-img-placeholder">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21 15 16 10 5 21"/>
                      </svg>
                    </div>
                  )
                }
                <div class="news-card-body">
                  <div class="news-card-meta">
                    <a href={`/${slugify(post.data.kategorie)}`} class="news-card-tag">{post.data.kategorie}</a>
                    <span class="news-card-date">
                      {post.data.datum.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' })}
                    </span>
                  </div>
                  <h2>{post.data.titulek}</h2>
                  <p>{post.data.perex}</p>
                  <a href={`/${post.slug}`} class="news-card-link">
                    Číst dál
                    <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </article>
            ))}
          </div>

        </div>
      </section>
    </>
  )}
</Layout>

<style>
  /* ARCHIV (rozcestník kategorie / štítku) */
  .archive { padding: var(--space-12) 0; }
  .section-label {
    display: inline-block;
    font-size: var(--text-label);
    font-weight: var(--font-bold);
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--clr-primary);
    margin-bottom: var(--space-2);
  }
  .archive h1 {
    font-family: var(--ff-head);
    font-size: var(--text-h1);
    color: var(--clr-heading);
    margin: 0 0 var(--space-6);
  }
  .archive-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  .related-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1.5px solid var(--clr-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow .2s, transform .2s;
  }
  .related-card:hover {
    box-shadow: 0 8px 28px rgba(0,0,0,.1);
    transform: translateY(-3px);
  }
  .related-card__img {
    aspect-ratio: 16 / 9;
    background: var(--clr-bg-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-muted);
    font-size: var(--text-sm);
    overflow: hidden;
  }
  .related-card__img img { width: 100%; height: 100%; object-fit: cover; }
  .related-card__body { padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-1); }
  .related-card__cat {
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: var(--clr-primary);
  }
  .related-card__title {
    font-family: var(--ff-head);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--clr-heading);
    line-height: 1.35;
  }
  .related-card__date { font-size: var(--text-meta); color: var(--clr-muted); }

  @media (max-width: 900px) { .archive-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .archive-grid { grid-template-columns: 1fr; } }

  /* ── KARTY (kopie z aktuality.astro — scoped styly nejsou globální) ── */
  .news-card {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    border: 1.5px solid var(--clr-border);
    display: flex;
    flex-direction: column;
    transition: box-shadow .2s, transform .2s;
    position: relative;
  }
  .news-card:hover {
    box-shadow: 0 8px 28px rgba(0,0,0,.1);
    transform: translateY(-3px);
  }
  .news-card-img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }
  .news-card-img-placeholder {
    width: 100%;
    aspect-ratio: 16/9;
    background: var(--clr-bg-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-muted);
  }
  .news-card-img-placeholder svg {
    width: 48px; height: 48px;
    stroke: var(--clr-border);
  }
  .news-card-body {
    padding: 22px 24px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .news-card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
    position: relative;
    z-index: 2;
  }
  .news-card-tag {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: var(--font-size-label);
    font-weight: 700;
    background: rgba(155,66,73,.12);
    color: var(--clr-primary);
    letter-spacing: .04em;
    text-decoration: none;
    cursor: pointer;
    transition: opacity .2s;
    position: relative;
    z-index: 2;
  }
  .news-card-tag:hover { opacity: .75; }
  .news-card-date {
    font-size: var(--font-size-meta);
    color: var(--clr-muted);
  }
  .news-card-body h2 {
    font-family: var(--ff-head);
    font-size: var(--font-size-perex);
    font-weight: 700;
    color: var(--clr-heading);
    line-height: 1.35;
    margin: 0 0 10px;
  }
  .news-card-body p {
    font-size: var(--font-size-caption);
    line-height: 1.65;
    color: var(--clr-text);
    margin: 0 0 16px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .news-card-cover-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .news-card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-caption);
    font-weight: 700;
    color: var(--clr-primary);
    text-decoration: none;
    margin-top: auto;
    transition: gap .2s;
    position: relative;
    z-index: 2;
  }
  .news-card-link:hover { gap: 10px; }
  .news-card-link svg {
    width: 16px; height: 16px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── ROZCESTNÍK KATEGORIE ── */
  .kat-hero {
    background: linear-gradient(135deg, var(--clr-primary) 0%, #7a3238 100%);
    color: #fff;
    padding: 72px 0 56px;
    position: relative;
    overflow: hidden;
  }
  .kat-hero::after {
    content: '';
    position: absolute;
    right: -80px; top: -80px;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: rgba(255,255,255,.06);
    pointer-events: none;
  }
  .kat-hero-inner { position: relative; z-index: 2; max-width: 680px; }
  .kat-hero .label {
    display: inline-block;
    font-size: var(--font-size-label);
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(255,255,255,.7);
    margin-bottom: 14px;
  }
  .kat-hero h1 {
    font-family: var(--ff-head);
    font-size: clamp(1.9rem, 4vw, 2.7rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 18px;
    line-height: 1.2;
  }
  .kat-hero .perex {
    font-size: var(--font-size-perex);
    line-height: 1.65;
    color: rgba(255,255,255,.85);
    margin: 0;
  }
  .kat-body {
    padding: 64px 0 80px;
    background: var(--clr-bg);
  }
  .kat-body .section-filter {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }
  .kat-body .filter-btn {
    padding: 8px 18px;
    border-radius: 20px;
    border: 1.5px solid var(--clr-border);
    background: #fff;
    color: var(--clr-text);
    font-family: var(--ff-body);
    font-size: var(--font-size-caption);
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all .18s;
    display: inline-block;
  }
  .kat-body .filter-btn:hover,
  .kat-body .filter-btn.active {
    background: var(--clr-primary);
    border-color: var(--clr-primary);
    color: #fff;
  }
  .kat-body .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  @media (max-width: 1024px) { .kat-body .news-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) {
    .kat-body .news-grid { grid-template-columns: 1fr; }
    .kat-hero { padding: 52px 0 40px; }
    .kat-body { padding: 44px 0 56px; }
  }
</style>
