---
// ════════════════════════════════════════════════════════════════
// PLOCHÁ DYNAMICKÁ ROUTA — vše na domena.cz/[slug]
// Rozlišuje 3 typy obsahu na stejné úrovni URL:
//   1. ČLÁNEK     → domena.cz/jak-funguje-tepelne-cerpadlo
//   2. KATEGORIE  → domena.cz/dotace (rozcestník článků kategorie)
//   3. ŠTÍTEK     → domena.cz/novostavba (rozcestník článků se štítkem)
// Žádné prefixy, žádné breadcrumbs.
// ════════════════════════════════════════════════════════════════
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { slugify } from '../utils/slug';

function formatDate(date: Date): string {
  return date.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}

export async function getStaticPaths() {
  const clanky = await getCollection('clanky');

  // 1) Cesty článků
  const clanekPaths = clanky.map((clanek) => ({
    params: { slug: clanek.slug },
    props: { type: 'clanek', clanek },
  }));

  // 2) Cesty kategorií (unikátní)
  const kategorie = [...new Set(clanky.map((c) => c.data.kategorie))];
  const kategoriePaths = kategorie.map((kat) => ({
    params: { slug: slugify(kat) },
    props: {
      type: 'kategorie',
      nazev: kat,
      clanky: clanky.filter((c) => c.data.kategorie === kat),
    },
  }));

  // 3) Cesty štítků (unikátní)
  const stitky = [...new Set(clanky.flatMap((c) => c.data.stitky))];
  const stitkyPaths = stitky.map((tag) => ({
    params: { slug: slugify(tag) },
    props: {
      type: 'stitek',
      nazev: tag,
      clanky: clanky.filter((c) => c.data.stitky.includes(tag)),
    },
  }));

  // KONTROLA KOLIZÍ: žádné dva slugy se nesmí krýt
  const all = [...clanekPaths, ...kategoriePaths, ...stitkyPaths];
  const seen = new Set();
  for (const p of all) {
    if (seen.has(p.params.slug)) {
      throw new Error(`KOLIZE SLUGU: "${p.params.slug}" existuje víckrát. Přejmenuj článek/kategorii/štítek.`);
    }
    seen.add(p.params.slug);
  }

  return all;
}

const { type } = Astro.props;

// ── ČLÁNEK ──
let Content, d;
if (type === 'clanek') {
  const rendered = await Astro.props.clanek.render();
  Content = rendered.Content;
  d = Astro.props.clanek.data;
}

// ── ROZCESTNÍK (kategorie / štítek) ──
const { nazev, clanky: vypisClanky } = Astro.props;

const schema = type === 'clanek'
  ? { '@type': 'Article', headline: d.titulek, datePublished: d.datum.toISOString(), author: { '@type': 'Person', name: d.autor }, articleSection: d.kategorie }
  : { '@type': 'CollectionPage', name: nazev };

const pageTitle = type === 'clanek' ? `${d.titulek}` : `${nazev} – články`;
const pageDesc = type === 'clanek' ? (d.popis || d.perex) : `Články v kategorii ${nazev}.`;
---
<Layout title={pageTitle} description={pageDesc} schema={schema}>
  {type === 'clanek' ? (
    <article class="single-post">
      <div class="container">
        <div class="single-post__head">
          <a class="single-post__cat" href={`/${slugify(d.kategorie)}`}>{d.kategorie}</a>
          <h1>{d.titulek}</h1>
          <p class="single-post__meta">{d.autor} · {formatDate(d.datum)}</p>
        </div>
        {d.nahled && <img class="single-post__cover" src={d.nahled} alt={d.titulek} />}
        <div class="single-post__body"><Content /></div>
        {d.stitky.length > 0 && (
          <div class="single-post__tags">
            {d.stitky.map((t) => <a href={`/${slugify(t)}`} class="post-tag">{t}</a>)}
          </div>
        )}
      </div>
    </article>
  ) : (
    <section class="archive">
      <div class="container">
        <span class="section-label">{type === 'kategorie' ? 'Kategorie' : 'Štítek'}</span>
        <h1>{nazev}</h1>
        <div class="archive-grid">
          {vypisClanky.map((c) => (
            <a href={`/${c.slug}`} class="related-card">
              <span class="related-card__img">{c.data.nahled ? <img src={c.data.nahled} alt={c.data.titulek} /> : '[ foto ]'}</span>
              <span class="related-card__body">
                <span class="related-card__cat">{c.data.kategorie}</span>
                <span class="related-card__title">{c.data.titulek}</span>
                <span class="related-card__date">{formatDate(c.data.datum)}</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  /* ════════════════════════════════════════════════════════════
     SINGLE POST — vzhled detailu článku (typografie podle Molti vzoru)
     Vše přes tokeny. Vzdušné sekce, výrazná hierarchie nadpisů.
     ════════════════════════════════════════════════════════════ */
  .single-post { padding: var(--space-8) 0 var(--space-12); }
  .single-post .container { max-width: 760px; }

  /* ── HLAVIČKA ČLÁNKU ── */
  .single-post__head { margin-bottom: var(--space-6); text-align: center; }
  .single-post__cat {
    display: inline-block;
    font-size: var(--text-label);
    font-weight: var(--font-bold);
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--clr-primary);
    text-decoration: none;
    margin-bottom: var(--space-3);
  }
  .single-post__cat:hover { text-decoration: underline; }
  .single-post h1 {
    font-family: var(--ff-head);
    font-size: clamp(1.9rem, 4vw, 2.7rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--clr-heading);
    margin: 0 0 var(--space-3);
  }
  .single-post__meta {
    color: var(--clr-muted);
    font-size: var(--text-sm);
  }

  /* ── ÚVODNÍ FOTKA ── */
  .single-post__cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-8);
  }

  /* ── TĚLO ČLÁNKU ── */
  .single-post__body {
    font-size: 1.075rem;
    line-height: 1.75;
    color: var(--clr-text-body);
  }
  .single-post__body :global(h2) {
    font-family: var(--ff-head);
    font-size: clamp(1.4rem, 2.6vw, 1.75rem);
    font-weight: 700;
    color: var(--clr-heading);
    line-height: 1.3;
    margin: var(--space-8) 0 var(--space-3);
    padding-top: var(--space-2);
  }
  .single-post__body :global(h3) {
    font-family: var(--ff-head);
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    font-weight: 700;
    color: var(--clr-heading);
    margin: var(--space-5) 0 var(--space-2);
  }
  .single-post__body :global(p) {
    margin: 0 0 var(--space-4);
  }
  .single-post__body :global(strong) { color: var(--clr-heading); font-weight: 700; }
  .single-post__body :global(ul),
  .single-post__body :global(ol) {
    margin: 0 0 var(--space-4);
    padding-left: 1.4em;
  }
  .single-post__body :global(li) { margin-bottom: var(--space-2); line-height: 1.7; }
  .single-post__body :global(a) {
    color: var(--clr-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .single-post__body :global(a:hover) { color: var(--clr-primary-hover); }
  .single-post__body :global(img) {
    width: 100%;
    border-radius: var(--radius-md);
    margin: var(--space-5) 0;
  }
  .single-post__body :global(hr) {
    border: none;
    border-top: 1px solid var(--clr-border);
    margin: var(--space-8) 0;
  }
  .single-post__body :global(blockquote) {
    border-left: 3px solid var(--clr-primary);
    padding: var(--space-2) 0 var(--space-2) var(--space-4);
    margin: var(--space-5) 0;
    color: var(--clr-muted);
    font-style: italic;
  }
  .single-post__body :global(em) { color: var(--clr-muted); }

  /* ── TABULKA V ČLÁNKU ── */
  .single-post__body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-5) 0;
    font-size: var(--text-sm);
  }
  .single-post__body :global(thead th) {
    background: var(--clr-primary-soft);
    color: var(--clr-heading);
    font-weight: 700;
    text-align: left;
    padding: var(--space-2) var(--space-3);
    border-bottom: 2px solid var(--clr-primary);
  }
  .single-post__body :global(tbody td) {
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--clr-border);
  }
  .single-post__body :global(tbody tr:nth-child(even)) {
    background: var(--clr-bg-alt);
  }

  /* ── ŠTÍTKY POD ČLÁNKEM ── */
  .single-post__tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-8);
    padding-top: var(--space-5);
    border-top: 1px solid var(--clr-border);
  }
  .post-tag {
    font-size: var(--text-sm);
    background: var(--clr-primary-soft);
    color: var(--clr-primary);
    padding: 6px 14px;
    border-radius: 999px;
    text-decoration: none;
    transition: background .2s, color .2s;
  }
  .post-tag:hover { background: var(--clr-primary); color: #fff; }

  /* ════════════════════════════════════════════════════════════
     ARCHIV (rozcestník kategorie / štítku)
     ════════════════════════════════════════════════════════════ */
  .archive { padding: var(--space-12) 0; }
  .section-label {
    display: inline-block;
    font-size: var(--text-label);
    font-weight: var(--font-bold);
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--clr-primary);
    margin-bottom: var(--space-2);
  }
  .archive h1 {
    font-family: var(--ff-head);
    font-size: var(--text-h1);
    color: var(--clr-heading);
    margin: 0 0 var(--space-6);
  }
  .archive-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  .related-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1.5px solid var(--clr-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow .2s, transform .2s;
  }
  .related-card:hover {
    box-shadow: 0 8px 28px rgba(0,0,0,.1);
    transform: translateY(-3px);
  }
  .related-card__img {
    aspect-ratio: 16 / 9;
    background: var(--clr-bg-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-muted);
    font-size: var(--text-sm);
    overflow: hidden;
  }
  .related-card__img img { width: 100%; height: 100%; object-fit: cover; }
  .related-card__body { padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-1); }
  .related-card__cat {
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: var(--clr-primary);
  }
  .related-card__title {
    font-family: var(--ff-head);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--clr-heading);
    line-height: 1.35;
  }
  .related-card__date { font-size: var(--text-meta); color: var(--clr-muted); }

  @media (max-width: 900px) { .archive-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .archive-grid { grid-template-columns: 1fr; } }
</style>
