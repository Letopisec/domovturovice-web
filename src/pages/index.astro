---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/blocks/PageHero.astro';
import TrustBar from '../components/blocks/TrustBar.astro';

const heroProps = {
  kicker: 'Registrovaný poskytovatel sociálních služeb',
  h1: 'Domov pro seniory v Olomouckém kraji – důstojná péče v Turovicích',
  perex: 'Péče o seniory v Domově Turovice stojí na jednoduchém principu – každý člověk si zaslouží žít důstojně, bezpečně a v místě, kde se cítí doma. Nabízíme individuální přístup, 24hodinový zdravotní dohled a prostředí, které podporuje samostatnost a zachovává životní radost.',
  bgImage: '/images/hero-bg.jpg',
  buttons: [
    { text: 'Zjistit podmínky přijetí', href: '/prijeti', variant: 'primary' },
    { text: 'Prohlédnout si domov', href: '/prostory', variant: 'outline' },
  ],
};

const trustItems = [
  {
    icon: 'map-pin',
    value: 'Klidná lokalita',
    label: 'Turovice, okres Přerov – zahrada s jezírkem, ovocný sad a bylinkový záhon',
  },
  {
    icon: 'building',
    value: '104 klientů',
    label: 'Každý v bytě s vlastním sociálním zázemím, lodžie, jídelna, zimní zahrada',
  },
  {
    icon: 'heart-handshake',
    value: 'Péče 24/7',
    label: 'Všeobecné sestry a pracovníci v přímé péči nepřetržitě, signalizace na každém pokoji',
  },
  {
    icon: 'mood-smile',
    value: 'Aktivní život',
    label: 'Canisterapie, muzikoterapie, arteterapie, ergoterapie a pravidelné kulturní akce',
  },
  {
    icon: 'shield-check',
    value: 'Ověřený provoz',
    label: 'Registrovaná sociální služba dle zákona č. 108/2006 Sb., standardy kvality MPSV',
  },
];
---

<Layout
  title="Domov pro seniory Olomoucký kraj – Domov Turovice, péče o seniory"
  description="Domov Turovice — péče o seniory s úctou a respektem. 104 klientů, vlastní byty, péče 24/7, registrovaná sociální služba."
>
  <PageHero {...heroProps} />
  <TrustBar items={trustItems} />
</Layout>
