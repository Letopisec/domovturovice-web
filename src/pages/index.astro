---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('clanky');
const latestPosts = allPosts
  .sort((a, b) => b.data.datum.valueOf() - a.data.datum.valueOf())
  .slice(0, 6);

function formatDate(date: Date): string {
  return date.toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });
}
---
<Layout
  title="Domov pro seniory Olomoucký kraj – Domov Turovice, péče o seniory"
  description="Domov Turovice nabízí seniorům důstojné bydlení, 24hodinovou péči a aktivizační program v Turovicích u Přerova."
>

<!-- ══ HERO ══ -->
<section class="hero">
  <!-- Desktop: full-screen foto na pozadí přes CSS (mobil nestahuje) -->
  <div class="hero-bg" role="img" aria-label="Domov Turovice budova a zahrada"></div>
  <div class="hero-overlay"></div>
  <!-- Mobilní foto banner — viditelný jen na mobilu, vložen do toku stránky -->
  <div class="hero-mobile-photo" aria-hidden="true">
    <picture>
      <source srcset="/images/hero-bg-mobile.webp" type="image/webp">
      <img src="/images/hero-bg.jpg" alt="" width="860" height="344" loading="eager" fetchpriority="high">
    </picture>
  </div>
  <div class="hero-content">
    <div class="hero-badge">
      <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
      Registrovaný poskytovatel sociálních služeb
    </div>
    <h1>Domov pro seniory v Olomouckém kraji – důstojná péče v Turovicích</h1>
    <p class="hero-perex">Péče o seniory v Domově Turovice stojí na jednoduchém principu – každý člověk si zaslouží žít důstojně, bezpečně a v místě, kde se cítí doma. Nabízíme individuální přístup, 24hodinový zdravotní dohled a prostředí, které podporuje samostatnost a zachovává životní radost.</p>
    <div class="hero-btn-wrap">
      <a href="/prijeti" class="hero-btn-primary"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg> Zjistit podmínky přijetí</a>
      <a href="/prijeti" class="hero-btn-secondary"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg> Zjistit podmínky přijetí</a>
    </div>
  </div>
  <div class="hero-scroll"><div class="hero-scroll-line"></div><span>Posunout dolů</span></div>
</section>

<!-- ══ RYCHLÝ PŘEHLED ══ -->
<section class="quick-strip has-circles">
  <div class="container">
    <div class="quick-grid">
      <div class="quick-item">
        <div class="quick-icon"><svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg></div>
        <p class="quick-title">Klidná lokalita</p>
        <p class="caption">Turovice, okres Přerov – zahrada s jezírkem, ovocný sad a bylinkový záhon</p>
      </div>
      <div class="quick-item">
        <div class="quick-icon"><svg viewBox="0 0 24 24"><path d="M4 10v7h3v-7H4zm6 0v7h3v-7h-3zM2 22h19v-3H2v3zm14-12v7h3v-7h-3zM11.5 1L2 6v2h19V6l-9.5-5z"/></svg></div>
        <p class="quick-title">104 klientů</p>
        <p class="caption">Každý v bytě s vlastním sociálním zázemím, lodžie, jídelna, zimní zahrada</p>
      </div>
      <div class="quick-item">
        <div class="quick-icon"><svg viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg></div>
        <p class="quick-title">Péče 24/7</p>
        <p class="caption">Všeobecné sestry a pracovníci v přímé péči nepřetržitě, signalizace na každém pokoji</p>
      </div>
      <div class="quick-item">
        <div class="quick-icon"><svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm3.51 9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/></svg></div>
        <p class="quick-title">Aktivní život</p>
        <p class="caption">Canisterapie, muzikoterapie, arteterapie, ergoterapie a pravidelné kulturní akce</p>
      </div>
      <div class="quick-item">
        <div class="quick-icon"><svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg></div>
        <p class="quick-title">Ověřený provoz</p>
        <p class="caption">Registrovaná sociální služba dle zákona č. 108/2006 Sb., standardy kvality MPSV</p>
      </div>
    </div>
  </div>
</section>

<!-- ══ O NÁS ══ -->
<section class="section about-section">
  <div class="container">
    <div class="about-grid">
      <div>
        <span class="section-label">O nás</span>
        <h2 class="section-h2">Náš příběh začal rozhodnutím udělat péči jinak</h2>
        <p>Domov Turovice vznikl z iniciativy Ziny Filip Dadlíkové, která svou dvacetiletou zkušeností z přímé práce se seniory přesvědčila investora, aby ze zchátralé obecní budovy vybudoval moderní domov. Zapsaný ústav byl založen v roce 2017, první klientka přišla v srpnu 2025.</p>
        <blockquote>„Nejde o velký anonymní ústav. Jde o místo, kde personál zná každého klienta jménem, kde se vaří z vlastní zahrady a kde se o svátcích zpívá, tančí i slaví."</blockquote>
        <p>Právě takový domov jsme chtěli vybudovat – a dnes ho žijeme každý den společně s našimi klienty.</p>
        <a href="/nas-pribeh" class="about-link">Přečtěte si náš příběh <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></a>
      </div>
      <div class="about-image">
        <picture>
              <source srcset="/images/about-foto.webp" type="image/webp">
              <img src="/images/about-foto.jpg" alt="Příběh Domova Turovice" loading="lazy" width="720" height="321">
            </picture>
      </div>
    </div>
  </div>
</section>

<!-- ══ PÉČE A SLUŽBY ══ -->
<section class="section care-section">
  <div class="container">
    <span class="section-label">Péče a služby</span>
    <h2 class="section-h2">Komplexní péče pod jednou střechou</h2>
    <p class="section-intro">Nabídka péče vychází z toho, co klient skutečně potřebuje. Každý klient má svůj individuální plán péče, který tým pravidelně přehodnocuje.</p>
    <div class="care-grid">
      <div class="care-card c-burg">
        <img class="care-card-img" src="/images/care-img1.jpg" alt="Ošetřovatelská péče" loading="lazy">
        <div class="care-card-body">
          <div class="care-icon"><svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg></div>
          <h3>Ošetřovatelská péče</h3>
          <p>Všeobecné sestry pečují o klienty nepřetržitě, 24 hodin denně. Starají se o podávání léků, ošetřování ran, sledování zdravotního stavu a komunikaci s lékaři.</p>
          <a href="/jak-pecujeme" class="care-card-btn">Jak pečujeme →</a>
        </div>
      </div>
      <div class="care-card c-burg">
        <img class="care-card-img" src="/images/care-img2.jpg" alt="Přímá osobní péče" loading="lazy">
        <div class="care-card-body">
          <div class="care-icon"><svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg></div>
          <h3>Přímá osobní péče</h3>
          <p>Pracovníci v přímé péči pomáhají při hygieně, oblékání, pohybu a dalších každodenních činnostech. Přístup je vždy šetrný a respektuje soukromí každého klienta.</p>
          <a href="/jak-pecujeme" class="care-card-btn">Náš přístup →</a>
        </div>
      </div>
      <div class="care-card c-orng">
        <img class="care-card-img" src="/images/care-img3.jpg" alt="Stravování" loading="lazy">
        <div class="care-card-body">
          <div class="care-icon"><svg viewBox="0 0 24 24"><path d="M18.06 22.99h1.66c.84 0 1.53-.64 1.63-1.46L23 5.05h-5V1h-1.97v4.05h-4.97l.3 2.34c1.71.47 3.31 1.32 4.27 2.26 1.44 1.42 2.43 2.89 2.43 5.29v8.05zM1 21.99V21h15.03v.99c0 .55-.45 1-1.01 1H2.01c-.56 0-1.01-.45-1.01-1zm15.03-7c0-8-15.03-8-15.03 0h15.03zM1.02 17h15v2H1z"/></svg></div>
          <h3>Stravování z vlastní kuchyně</h3>
          <p>Klienti dostávají pět jídel denně. Jídla se připravují v domácí kuchyni, kde kuchaři v sezóně pracují i s vlastní zeleninou ze skleníku.</p>
          <a href="/stravovani" class="care-card-btn">O stravování →</a>
        </div>
      </div>
      <div class="care-card c-gren">
        <img class="care-card-img" src="/images/care-img4.jpg" alt="Aktivizace seniorů" loading="lazy">
        <div class="care-card-body">
          <div class="care-icon"><svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm3.51 9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/></svg></div>
          <h3>Aktivizace a volný čas</h3>
          <p>Každý den probíhají aktivity přizpůsobené kondici klientů – trénink paměti, arteterapie, canisterapie nebo muzikoterapie.</p>
          <a href="/aktivizace" class="care-card-btn">Program aktivit →</a>
        </div>
      </div>
      <div class="care-card c-blue">
        <img class="care-card-img" src="/images/care-img5.jpg" alt="Sociální poradenství" loading="lazy">
        <div class="care-card-body">
          <div class="care-icon"><svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-7 9h-2V5h2v6zm0 4h-2v-2h2v2z"/></svg></div>
          <h3>Sociální poradenství</h3>
          <p>Sociální pracovnice pomáhají klientům i rodinám s administrativou – od vyřízení příspěvku na péči až po komunikaci s úřady.</p>
          <a href="/prijeti" class="care-card-btn">Poradenství →</a>
        </div>
      </div>
      <div class="care-card c-orng">
        <img class="care-card-img" src="/images/care-img6.jpg" alt="Rehabilitace a ergoterapie" loading="lazy">
        <div class="care-card-body">
          <div class="care-icon"><svg viewBox="0 0 24 24"><path d="M13.49 5.48c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm-3.6 13.9l1-4.4 2.1 2v6h2v-7.5l-2.1-2 .6-3c1.3 1.5 3.3 2.5 5.5 2.5v-2c-1.9 0-3.5-1-4.3-2.4l-1-1.6c-.4-.6-1-1-1.7-1-.3 0-.5.1-.8.1l-5.2 2.2v4.7h2v-3.4l1.8-.7-1.6 8.1-4.9-1-.4 2 7 1.4z"/></svg></div>
          <h3>Rehabilitace a ergoterapie</h3>
          <p>Rehabilitační program podporuje pohyblivost a soběstačnost. Ergoterapie pomáhá nacvičovat každodenní dovednosti.</p>
          <a href="/jak-pecujeme" class="care-card-btn">Rehabilitace →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ PROSTORY ══ -->
<section class="spaces-section">
  <div class="container">
    <div class="spaces-title-row">
      <div>
        <span class="section-label">Prostory a zázemí</span>
        <h2 class="section-h2" style="margin-bottom:0">Podívejte se, jak to u nás vypadá</h2>
      </div>
      <a href="/prostory" class="about-link" style="flex-shrink:0">Prohlídka celého domova <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></a>
    </div>
    <div class="spaces-grid">
      <div class="spaces-main"><img src="/images/spaces-main.jpg" alt="Prostory Domova Turovice" style="border-radius:12px" loading="lazy"></div>
      <div class="spaces-col">
        <div class="spaces-side"><img src="/images/spaces-side1.jpg" alt="Pokoj klienta" style="border-radius:12px" loading="lazy"></div>
        <div class="spaces-side"><img src="/images/spaces-side2.jpg" alt="Zahrada a jezírko" style="border-radius:12px" loading="lazy"></div>
      </div>
    </div>
  </div>
</section>

<!-- ══ PŘIJETÍ – KROKY ══ -->
<section class="section steps-section">
  <div class="container">
    <span class="section-label">Přijetí do domova</span>
    <h2 class="section-h2">Cesta do Domova Turovice je jednoduchá</h2>
    <p class="section-intro">Přijetí do domova pro seniory nemusí být složitý proces. Provedeme vás každým krokem a odpovíme na všechny otázky, které vás zajímají.</p>
    <div class="steps-grid">
      <div class="steps-connector"></div>
      <div class="step-item">
        <div class="step-num">1</div>
        <p class="step-title">Kontaktujte nás</p>
        <p>Zavolejte nebo napište. Rádi vám odpovíme na první otázky a pomůžeme s žádostí o přijetí.</p>
      </div>
      <div class="step-item">
        <div class="step-num">2</div>
        <p class="step-title">Prohlídka a první rozhovor</p>
        <p>Ukážeme vám prostory, představíme tým a popovídáme si o potřebách vašeho blízkého.</p>
      </div>
      <div class="step-item">
        <div class="step-num">3</div>
        <p class="step-title">Vyplnění žádosti</p>
        <p>Vyplníte žádost o přijetí a přiložíte vyjádření lékaře. Poradíme, jak vyřídit příspěvek na péči.</p>
      </div>
      <div class="step-item">
        <div class="step-num">4</div>
        <p class="step-title">Přijetí a adaptace</p>
        <p>Po přijetí věnujeme každému klientovi zvýšenou pozornost. Tým zpracuje individuální plán péče.</p>
      </div>
    </div>
    <div class="steps-cta">
      <a href="/prijeti" class="about-link" style="justify-content:center">Více o procesu přijetí a potřebných dokumentech <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></a>
    </div>
  </div>
</section>

<!-- ══ CENÍK ══ -->
<section class="section pricing-section has-circles">
  <div class="container">
    <span class="section-label">Ceník</span>
    <h2 class="section-h2">Transparentní ceník bez překvapení</h2>
    <p class="section-intro">Ceny jsou stanoveny v souladu s vyhláškou č. 505/2006 Sb. Níže uvádíme orientační přehled.</p>
    <div class="pricing-grid">
      <div class="pricing-card">
        <h3>Jednolůžkový pokoj</h3>
        <div class="pricing-price">670 Kč <span>/ den</span></div>
        <p>Celková denní úhrada za ubytování a stravu. Součástí je vlastní pokoj o velikosti 12,6 m² s předsíní a sociálním zázemím.</p>
      </div>
      <div class="pricing-card">
        <div class="pricing-badge">S lodžií</div>
        <h3>Dvoulůžkový pokoj s balkónem</h3>
        <div class="pricing-price">625 Kč <span>/ den</span></div>
        <p>Pokoj s lodžií o velikosti 9,2 m² a větší podlahovou plochou 15,1 m². Vhodný pro páry nebo jako komfortnější varianta.</p>
      </div>
      <div class="pricing-card positive">
        <div class="pricing-badge">Státní podpora</div>
        <div class="pricing-price-note">✓ Snižuje vaše náklady</div>
        <h3>Příspěvek na péči</h3>
        <div class="pricing-price">Až 19 200 Kč <span>/ měsíc</span></div>
        <p>Velkou část nákladů pokryje příspěvek na péči přiznaný Úřadem práce ČR. Výše závisí na stupni závislosti klienta (I.–IV. stupeň). Pomůžeme vám ho vyřídit.</p>
        <a href="/cenik" class="about-link" style="color:var(--clr-green)">Jak příspěvek vyřídit <svg viewBox="0 0 24 24" style="fill:var(--clr-green)"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></a>
      </div>
    </div>
    <p class="pricing-note">Měsíční náklady se pohybují v rozmezí 18 750 – 20 100 Kč dle počtu dní a typu pokoje. &nbsp;<a href="/cenik">Zobrazit úplný ceník →</a></p>
  </div>
</section>

<!-- ══ BLOG SLIDER ══ -->
<section class="section blog-section">
  <div class="container">
    <div class="blog-header">
      <div>
        <span class="section-label">Aktuality a blog</span>
        <h2 class="section-h2" style="margin-bottom:0">Co se u nás děje</h2>
      </div>
      <a href="/aktuality" class="btn btn-secondary">Všechny aktuality →</a>
    </div>
    <div class="blog-track-outer">
      <div class="blog-track" id="blogTrack">
        {latestPosts.map((post) => (
          <a href={`/${post.slug}`} class="blog-card">
            {post.data.nahled
              ? <img class="blog-card-img" src={post.data.nahled} alt={post.data.titulek} loading="lazy" />
              : <div class="blog-card-img" style="background:var(--clr-bg-alt);aspect-ratio:16/9;"></div>
            }
            <div class="blog-card-body">
              <span class="blog-cat">{post.data.kategorie}</span>
              <div class="blog-card-date">{formatDate(post.data.datum)}</div>
              <h3>{post.data.titulek}</h3>
              <p>{post.data.perex}</p>
              <span class="blog-more">Číst více →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
    <div class="blog-nav">
      <button class="blog-btn" id="blogPrev" aria-label="Předchozí">
        <svg viewBox="0 0 24 24"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"/></svg>
      </button>
      <div class="blog-dots" id="blogDots"></div>
      <button class="blog-btn" id="blogNext" aria-label="Následující">
        <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- ══ PRO RODINY ══ -->
