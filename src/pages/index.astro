---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/blocks/PageHero.astro';
import TrustBar from '../components/blocks/TrustBar.astro';
import SplitSection from '../components/blocks/SplitSection.astro';
import Steps from '../components/blocks/Steps.astro';
import CTASection from '../components/blocks/CTASection.astro';

const heroProps = {
  kicker: 'Registrovaný poskytovatel sociálních služeb',
  h1: 'Domov pro seniory v Olomouckém kraji – důstojná péče v Turovicích',
  perex: 'Péče o seniory v Domově Turovice stojí na jednoduchém principu – každý člověk si zaslouží žít důstojně, bezpečně a v místě, kde se cítí doma. Nabízíme individuální přístup, 24hodinový zdravotní dohled a prostředí, které podporuje samostatnost a zachovává životní radost.',
  bgImage: '/images/hero-bg.jpg',
  buttons: [
    { text: 'Zjistit podmínky přijetí', href: '/prijeti', variant: 'primary' },
    { text: 'Prohlédnout si domov', href: '/prostory', variant: 'secondary' },
  ],
};

const aboutParagraphs = [
  'Domov Turovice vznikl z iniciativy Ziny Filip Dadlíkové, která svou dvacetiletou zkušeností z přímé práce se seniory přesvědčila investora, aby ze zchátralé obecní budovy vybudoval moderní domov. Zapsaný ústav byl založen v roce 2017, první klientka přišla v srpnu 2025.',
  '„Nejde o velký anonymní ústav. Jde o místo, kde personál zná každého klienta jménem, kde se vaří z vlastní zahrady a kde se o svátcích zpívá, tančí i slaví."',
  'Právě takový domov jsme chtěli vybudovat – a dnes ho žijeme každý den společně s našimi klienty.',
];

const trustItems = [
  {
    icon: 'map-pin',
    value: 'Klidná lokalita',
    label: 'Turovice, okres Přerov – zahrada s jezírkem, ovocný sad a bylinkový záhon',
  },
  {
    icon: 'building',
    value: '104 klientů',
    label: 'Každý v bytě s vlastním sociálním zázemím, lodžie, jídelna, zimní zahrada',
  },
  {
    icon: 'heart-handshake',
    value: 'Péče 24/7',
    label: 'Všeobecné sestry a pracovníci v přímé péči nepřetržitě, signalizace na každém pokoji',
  },
  {
    icon: 'mood-smile',
    value: 'Aktivní život',
    label: 'Canisterapie, muzikoterapie, arteterapie, ergoterapie a pravidelné kulturní akce',
  },
  {
    icon: 'shield-check',
    value: 'Ověřený provoz',
    label: 'Registrovaná sociální služba dle zákona č. 108/2006 Sb., standardy kvality MPSV',
  },
];
---

<Layout
  title="Domov pro seniory Olomoucký kraj – Domov Turovice, péče o seniory"
  description="Domov Turovice — péče o seniory s úctou a respektem. 104 klientů, vlastní byty, péče 24/7, registrovaná sociální služba."
>
  <PageHero {...heroProps} />
  <TrustBar items={trustItems} />

  <SplitSection
    label="O nás"
    heading="Náš příběh začal rozhodnutím udělat péči jinak"
    paragraphs={aboutParagraphs}
    image="/images/about-foto.jpg"
    imageAlt="Příběh Domova Turovice"
    link={{ text: 'Přečtěte si náš příběh', href: '/nas-pribeh' }}
    imagePosition="right"
  />

  <section class="section care-section" style="padding: 80px 0; background: var(--color-bg);">
    <div class="container">
      <span class="section-label">Péče a služby</span>
      <h2 class="section-h2">Komplexní péče pod jednou střechou</h2>
      <p class="section-intro">Nabídka péče vychází z toho, co klient skutečně potřebuje. Každý klient má svůj individuální plán péče, který tým pravidelně přehodnocuje.</p>
      <div class="care-grid">

        <div class="care-card c-burg">
          <img class="care-card-img" src="/images/care-img1.jpg" alt="Ošetřovatelská péče" loading="lazy">
          <div class="care-card-body">
            <div class="care-icon"><svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg></div>
            <h3>Ošetřovatelská péče</h3>
            <p>Všeobecné sestry pečují o klienty nepřetržitě, 24 hodin denně. Starají se o podávání léků, ošetřování ran, sledování zdravotního stavu a komunikaci s lékaři.</p>
            <a href="/jak-pecujeme" class="care-card-btn">Jak pečujeme →</a>
          </div>
        </div>

        <div class="care-card c-burg">
          <img class="care-card-img" src="/images/care-img2.jpg" alt="Přímá osobní péče" loading="lazy">
          <div class="care-card-body">
            <div class="care-icon"><svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg></div>
            <h3>Přímá osobní péče</h3>
            <p>Pracovníci v přímé péči pomáhají při hygieně, oblékání, pohybu a dalších každodenních činnostech. Přístup je vždy šetrný a respektuje soukromí každého klienta.</p>
            <a href="/jak-pecujeme" class="care-card-btn">Náš přístup →</a>
          </div>
        </div>

        <div class="care-card c-orng">
          <img class="care-card-img" src="/images/care-img3.jpg" alt="Stravování" loading="lazy">
          <div class="care-card-body">
            <div class="care-icon"><svg viewBox="0 0 24 24"><path d="M18.06 22.99h1.66c.84 0 1.53-.64 1.63-1.46L23 5.05h-5V1h-1.97v4.05h-4.97l.3 2.34c1.71.47 3.31 1.32 4.27 2.26 1.44 1.42 2.43 2.89 2.43 5.29v8.05zM1 21.99V21h15.03v.99c0 .55-.45 1-1.01 1H2.01c-.56 0-1.01-.45-1.01-1zm15.03-7c0-8-15.03-8-15.03 0h15.03zM1.02 17h15v2H1z"/></svg></div>
            <h3>Stravování z vlastní kuchyně</h3>
            <p>Klienti dostávají pět jídel denně. Jídla se připravují v domácí kuchyni, kde kuchaři v sezóně pracují i s vlastní zeleninou ze skleníku.</p>
            <a href="/stravovani" class="care-card-btn">O stravování →</a>
          </div>
        </div>

        <div class="care-card c-gren">
          <img class="care-card-img" src="/images/care-img4.jpg" alt="Aktivizace seniorů" loading="lazy">
          <div class="care-card-body">
            <div class="care-icon"><svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm3.51 9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/></svg></div>
            <h3>Aktivizace a volný čas</h3>
            <p>Každý den probíhají aktivity přizpůsobené kondici klientů – trénink paměti, arteterapie, canisterapie nebo muzikoterapie.</p>
            <a href="/aktivizace" class="care-card-btn">Program aktivit →</a>
          </div>
        </div>

        <div class="care-card c-blue">
          <img class="care-card-img" src="/images/care-img5.jpg" alt="Sociální poradenství" loading="lazy">
          <div class="care-card-body">
            <div class="care-icon"><svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-7 9h-2V5h2v6zm0 4h-2v-2h2v2z"/></svg></div>
            <h3>Sociální poradenství</h3>
            <p>Sociální pracovnice pomáhají klientům i rodinám s administrativou – od vyřízení příspěvku na péči až po komunikaci s úřady.</p>
            <a href="/prijeti" class="care-card-btn">Poradenství →</a>
          </div>
        </div>

        <div class="care-card c-orng">
          <img class="care-card-img" src="/images/care-img6.jpg" alt="Rehabilitace a ergoterapie" loading="lazy">
          <div class="care-card-body">
            <div class="care-icon"><svg viewBox="0 0 24 24"><path d="M13.49 5.48c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm-3.6 13.9l1-4.4 2.1 2v6h2v-7.5l-2.1-2 .6-3c1.3 1.5 3.3 2.5 5.5 2.5v-2c-1.9 0-3.5-1-4.3-2.4l-1-1.6c-.4-.6-1-1-1.7-1-.3 0-.5.1-.8.1l-5.2 2.2v4.7h2v-3.4l1.8-.7-1.6 8.1-4.9-1-.4 2 7 1.4z"/></svg></div>
            <h3>Rehabilitace a ergoterapie</h3>
            <p>Rehabilitační program podporuje pohyblivost a soběstačnost. Ergoterapie pomáhá nacvičovat každodenní dovednosti.</p>
            <a href="/jak-pecujeme" class="care-card-btn">Rehabilitace →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Steps
    kicker="Přijetí do domova"
    heading="Cesta do Domova Turovice je jednoduchá"
    lead="Přijetí do domova pro seniory nemusí být složitý proces. Provedeme vás každým krokem a odpovíme na všechny otázky, které vás zajímají."
    steps={[
      { title: 'Kontaktujte nás', text: 'Zavolejte nebo napište. Rádi vám odpovíme na první otázky a pomůžeme s žádostí o přijetí.' },
      { title: 'Podejte žádost', text: 'Vyplníte žádost o přijetí spolu s vyjádřením lékaře o zdravotním stavu. Žádost posoudíme a zařadíme do evidence.' },
      { title: 'Sociální šetření', text: 'Naše sociální pracovnice přijede za vámi domů, aby poznala situaci a potřeby vašeho blízkého.' },
      { title: 'Podpis smlouvy a nastěhování', text: 'Po uvolnění místa vás kontaktujeme, domluvíme termín, podepíšeme smlouvu a váš blízký se nastěhuje.' },
    ]}
    link={{ text: 'Více o procesu přijetí a potřebných dokumentech', href: '/prijeti' }}
  />

  <section class="section spaces-section" style="padding: 80px 0;">
    <div class="container">
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:32px; flex-wrap:wrap; gap:16px;">
        <div>
          <span class="section-label">Prostory a zázemí</span>
          <h2 class="section-h2" style="margin-bottom:0">Podívejte se, jak to u nás vypadá</h2>
        </div>
        <a href="/prostory" class="about-link" style="flex-shrink:0">
          Prohlídka celého domova <i class="ti ti-arrow-right"></i>
        </a>
      </div>
      <div style="display:grid; grid-template-columns:2fr 1fr; gap:12px;">
        <img src="/images/spaces-main.jpg" alt="Prostory Domova Turovice"
          style="width:100%; height:420px; object-fit:cover; border-radius:12px;" loading="lazy">
        <div style="display:flex; flex-direction:column; gap:12px;">
          <img src="/images/spaces-side1.jpg" alt="Pokoj klienta"
            style="width:100%; height:204px; object-fit:cover; border-radius:12px;" loading="lazy">
          <img src="/images/spaces-side2.jpg" alt="Zahrada a jezírko"
            style="width:100%; height:204px; object-fit:cover; border-radius:12px;" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <section class="section pricing-section" style="padding: 80px 0; background: var(--color-primary-soft);">
    <div class="container">
      <span class="section-label">Ceník</span>
      <h2 class="section-h2">Transparentní ceník bez překvapení</h2>
      <p class="section-intro">Celá cena péče se skládá z úhrady z 11 925 Kč + příspěvek na péči od MPSV.</p>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px; position:relative; z-index:1;">
        <div style="background:var(--color-white); border-radius:var(--radius-card); box-shadow:var(--shadow-card); padding:32px 28px 36px; display:flex; flex-direction:column; gap:12px;">
          <span style="display:inline-block; background:var(--color-primary-soft); color:var(--color-primary); font-size:var(--text-label); font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:4px 10px; border-radius:4px; align-self:flex-start;">JEDNOLŮŽKOVÝ POKOJ</span>
          <p style="font-family:var(--font-serif); font-size:var(--text-price-lg); font-weight:700; color:var(--color-primary); line-height:1.1; margin:0;">670 Kč<span style="font-family:var(--font-sans); font-size:var(--text-caption); font-weight:400; color:var(--color-text-muted);">/den</span></p>
          <p style="font-size:var(--text-body); line-height:1.70; color:var(--color-text);">Vlastní sociální zázemí, lodžie u vybraných pokojů.</p>
        </div>
        <div style="background:var(--color-white); border-radius:var(--radius-card); box-shadow:var(--shadow-card); padding:32px 28px 36px; display:flex; flex-direction:column; gap:12px; border:2px solid var(--color-primary); position:relative;">
          <span style="position:absolute; top:-14px; left:24px; background:var(--color-primary); color:white; font-size:var(--text-label); font-weight:700; letter-spacing:0.06em; text-transform:uppercase; padding:4px 12px; border-radius:4px;">NEJOBLÍBENĚJŠÍ</span>
          <span style="display:inline-block; background:var(--color-primary-soft); color:var(--color-primary); font-size:var(--text-label); font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:4px 10px; border-radius:4px; align-self:flex-start;">JEDNOLŮŽKOVÝ S BALKONEM</span>
          <p style="font-family:var(--font-serif); font-size:var(--text-price-lg); font-weight:700; color:var(--color-primary); line-height:1.1; margin:0;">625 Kč<span style="font-family:var(--font-sans); font-size:var(--text-caption); font-weight:400; color:var(--color-text-muted);">/den</span></p>
          <p style="font-size:var(--text-body); line-height:1.70; color:var(--color-text);">Vlastní sociální zázemí + balkon s výhledem do zahrady.</p>
        </div>
        <div style="background:linear-gradient(135deg, #f0f8f0 0%, #e6f4e6 100%); border:2px solid var(--color-theme-green); border-radius:var(--radius-card); box-shadow:var(--shadow-card); padding:32px 28px 36px; display:flex; flex-direction:column; gap:12px;">
          <span style="display:inline-block; background:var(--color-theme-green-soft); color:var(--color-theme-green); font-size:var(--text-label); font-weight:700; letter-spacing:0.08em; text-transform:uppercase; padding:4px 10px; border-radius:4px; align-self:flex-start;">PŘÍSPĚVEK NA PÉČI</span>
          <p style="font-family:var(--font-serif); font-size:var(--text-price-lg); font-weight:700; color:var(--color-theme-green); line-height:1.1; margin:0;">až 19 200 Kč<span style="font-family:var(--font-sans); font-size:var(--text-caption); font-weight:400; color:var(--color-text-muted);">/měs</span></p>
          <p style="font-size:var(--text-body); line-height:1.70; color:var(--color-text);">Příspěvek na péči od MPSV hradí část nákladů. Pomůžeme s vyřízením.</p>
        </div>
      </div>
      <p style="margin-top:24px; font-size:var(--text-small); color:var(--color-text-muted);">
        Uvedené ceny jsou za ubytování a stravu. Péče je hrazena z příspěvku na péči a zdravotního pojištění.
        <a href="/cenik" style="color:var(--color-primary); font-weight:600;">Podrobný ceník →</a>
      </p>
    </div>
  </section>

  <section class="section" style="padding: 80px 0;">
    <div class="container">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:40px; flex-wrap:wrap; gap:16px;">
        <div>
          <span class="section-label">Co se u nás děje</span>
          <h2 class="section-h2" style="margin-bottom:0">Aktuality z domova</h2>
        </div>
        <a href="/aktuality" class="about-link">Všechny aktuality <i class="ti ti-arrow-right"></i></a>
      </div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">
        <div style="background:var(--color-white); border-radius:var(--radius-card); overflow:hidden; box-shadow:var(--shadow-card);">
          <img src="/images/blog-1.jpg" alt="Aktualita ze zahrady" style="width:100%; height:200px; object-fit:cover;" loading="lazy">
          <div style="padding:24px;">
            <p style="font-size:var(--text-meta); color:var(--color-text-muted); margin-bottom:8px;">Aktivity</p>
            <h3 style="font-size:var(--text-h4); font-family:var(--font-serif); margin-bottom:12px; line-height:1.3;">Z naší zahrady přímo na stůl – sezóna sklizně začíná</h3>
            <a href="/aktuality" class="about-link" style="font-size:var(--text-small);">Číst více <i class="ti ti-arrow-right"></i></a>
          </div>
        </div>
        <div style="background:var(--color-white); border-radius:var(--radius-card); overflow:hidden; box-shadow:var(--shadow-card);">
          <img src="/images/blog-2.jpg" alt="Muzikoterapie" style="width:100%; height:200px; object-fit:cover;" loading="lazy">
          <div style="padding:24px;">
            <p style="font-size:var(--text-meta); color:var(--color-text-muted); margin-bottom:8px;">Terapie</p>
            <h3 style="font-size:var(--text-h4); font-family:var(--font-serif); margin-bottom:12px; line-height:1.3;">Muzikoterapie – senioři společně zpěv šíří dál</h3>
            <a href="/aktuality" class="about-link" style="font-size:var(--text-small);">Číst více <i class="ti ti-arrow-right"></i></a>
          </div>
        </div>
        <div style="background:var(--color-white); border-radius:var(--radius-card); overflow:hidden; box-shadow:var(--shadow-card);">
          <img src="/images/blog-3.jpg" alt="Spolupráce s nemocnicí" style="width:100%; height:200px; object-fit:cover;" loading="lazy">
          <div style="padding:24px;">
            <p style="font-size:var(--text-meta); color:var(--color-text-muted); margin-bottom:8px;">Spolupráce</p>
            <h3 style="font-size:var(--text-h4); font-family:var(--font-serif); margin-bottom:12px; line-height:1.3;">Zahajujeme spolupráci s hranickou nemocnicí</h3>
            <a href="/aktuality" class="about-link" style="font-size:var(--text-small);">Číst více <i class="ti ti-arrow-right"></i></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <SplitSection
    label=""
    heading="Rozhodnutí, se kterým vám můžeme pomoci"
    paragraphs={[
      'Hledáte bezpečné a důstojné místo pro svého blízkého? Chápeme, že jde o jedno z nejtěžších rozhodnutí v životě rodiny.',
      'V Domově Turovice jsme tu od toho, abychom vás celým procesem provedli – od první otázky až po nastěhování. Zavolejte nebo přijeďte na prohlídku.',
    ]}
    image="/images/about-foto2.jpg"
    imageAlt="Péče v Domově Turovice"
    imagePosition="left"
    link={{ text: 'Domluvit prohlídku', href: '/kontakt' }}
    bg="surface"
  />

  <CTASection
    heading="Přijeďte se podívat. Zavolejte. Napište."
    text="Rádi vám ukážeme domov osobně a odpovíme na všechny otázky."
    buttons={[
      { text: 'Kontaktujte nás', href: '/kontakt', variant: 'primary' },
      { text: 'Přijeďte na prohlídku', href: '/prostory', variant: 'secondary' },
      { text: 'Podmínky přijetí', href: '/prijeti', variant: 'secondary' },
    ]}
  />
</Layout>

<style is:global>
  /* ── CARE GRID — Péče a služby ── */
  .care-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .care-card {
    background: var(--color-white, #fff);
    border-radius: var(--radius-card, 12px);
    box-shadow: var(--shadow-card, 0 2px 12px rgba(0,0,0,0.08));
    overflow: hidden;
    transition: box-shadow 0.25s, transform 0.25s;
    position: relative;
    display: flex; flex-direction: column;
  }
  .care-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; z-index: 1;
  }
  .care-card.c-burg::before { background: var(--color-primary); }
  .care-card.c-orng::before { background: #c87d0e; }
