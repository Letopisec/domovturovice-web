HERO_CSS: OK
---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Domov pro seniory Turovice – náš příběh a poslání | Olomoucký kraj"
  description="Jak vznikl Domov Turovice a na čem stavíme péči o seniory v Olomouckém kraji. Přečtěte si náš příběh a poznejte nás dřív, než zavoláte."
>

<style>
/* ══ HERO ══ */ /* seo-2026-05-29 */
.page-hero{
  background:linear-gradient(135deg,var(--clr-primary) 0%,#7a3238 100%);
  color:#fff;
  padding:72px 0 60px;
  position:relative;
  overflow:hidden;
}
.page-hero::after{
  content:'';
  position:absolute;
  right:-80px;top:-80px;
  width:400px;height:400px;
  border-radius:50%;
  background:rgba(255,255,255,.06);
  pointer-events:none;
}
.page-hero-inner{
  position:relative;
  z-index:2;
  max-width:680px;
}
.page-hero-kicker{
  display:inline-block;
  font-family:var(--font-body);
  font-size:var(--font-size-label);
  font-weight:700;
  letter-spacing:0.10em;
  text-transform:uppercase;
  color:rgba(255,255,255,0.70);
  margin-bottom:14px;
}
.page-hero h1{
  color:#fff;
  margin-bottom:16px;
}
.page-hero h1 em{
  font-style:italic;
  color:rgba(255,255,255,0.80);
}
.hero-perex{
  font-size:var(--font-size-perex);
  color:rgba(255,255,255,0.88);
  line-height:1.6;
  max-width:580px;
  margin:0 0 28px;
}
.hero-cta{
  display:inline-flex;
  align-items:center;
  gap:8px;
  background:rgba(255,255,255,0.15);
  border:1px solid rgba(255,255,255,0.30);
  color:#fff;
  font-family:var(--font-body);
  font-size:var(--font-size-ui);
  font-weight:600;
  padding:11px 22px;
  border-radius:var(--radius-btn);
  text-decoration:none;
  transition:background .2s;
}
.hero-cta:hover{background:rgba(255,255,255,0.25);}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;margin-top:4px;}

/* ══ STORY SECTIONS ══ */
.story-section{padding:88px 0;}
.story-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:72px;
  align-items:center;
}
.story-grid.reverse{direction:rtl;}
.story-grid.reverse > *{direction:ltr;}

.story-year{
  font-family:var(--font-display);
  font-size:56px;
  font-weight:700;
  color:var(--clr-border);
  line-height:1;
  margin-bottom:-12px;
  display:block;
  letter-spacing:-0.02em;
}
.story-text h2{margin-bottom:20px;}
.story-text p{
  font-size:var(--font-size-base);
  color:var(--clr-text-body);
  line-height:1.75;
  margin-bottom:16px;
}
.story-text p:last-child{margin-bottom:0;}

/* ══ PHOTO PLACEHOLDER ══ */
.photo-slot{
  border-radius:var(--radius-card);
  background:var(--clr-surface);
  border:1px solid var(--clr-border);
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:10px;
  color:var(--clr-text-muted);
  text-align:center;
  padding:32px 24px;
}
.photo-slot svg{
  width:36px;height:36px;
  opacity:0.30;
  flex-shrink:0;
}
.photo-slot-label{
  font-size:var(--font-size-caption);
  line-height:1.5;
  color:var(--clr-text-muted);
}
.photo-slot-dim{
  font-size:var(--font-size-meta);
  font-weight:700;
  color:var(--clr-primary);
  background:var(--clr-primary-soft);
  padding:3px 10px;
  border-radius:20px;
  margin-top:4px;
}
/* portrait = ředitelka */
.photo-slot.portrait{aspect-ratio:3/4;}
/* landscape = story */
.photo-slot.landscape{aspect-ratio:4/3;}

/* ══ ZÁVAZEK ══ */
.zavazek-section{
  padding:88px 0;
  background:var(--clr-primary-soft);
  position:relative;
  overflow:hidden;
}
.zavazek-section::before{
  content:'';position:absolute;
  width:340px;height:340px;border-radius:50%;
  background:rgba(155,66,73,0.06);
  top:-80px;right:-60px;
}
.zavazek-section::after{
  content:'';position:absolute;
  width:200px;height:200px;border-radius:50%;
  background:rgba(155,66,73,0.04);
  bottom:-40px;left:-40px;
}
.zavazek-inner{
  max-width:820px;
  margin:0 auto;
  text-align:center;
  position:relative;
  z-index:1;
}
.zavazek-inner h2{margin-bottom:12px;}
.zavazek-lead{
  font-size:var(--font-size-base);
  color:var(--clr-text-body);
  line-height:1.7;
  margin-bottom:0;
}
.zavazek-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:24px;
  text-align:left;
  margin-top:40px;
}
.zavazek-card{
  background:var(--clr-white);
  border-radius:var(--radius-card);
  padding:28px 24px;
  box-shadow:var(--shadow-card);
  border-top:3px solid var(--clr-primary);
}
.zavazek-card h3{
  font-family:var(--font-display);
  font-size:var(--font-size-h4);
  font-weight:600;
  color:var(--clr-text-dark);
  margin-bottom:10px;
}
.zavazek-card p{
  font-size:var(--font-size-small);
  color:var(--clr-text-body);
  line-height:1.65;
  margin:0;
}

/* ══ HODNOTY ══ */
.hodnoty-section{padding:88px 0;}
.section-intro{
  text-align:center;
  max-width:580px;
  margin:0 auto 52px;
}
.section-intro h2{margin-bottom:14px;}
.section-intro p{
  font-size:var(--font-size-base);
  color:var(--clr-text-muted);
  line-height:1.7;
  margin:0;
}
.hodnoty-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:24px;
}
/* 6 karet = 2 řady po 3 */
.hodnota-card{
  background:var(--clr-bg);
  border-radius:var(--radius-card);
  padding:36px 28px;
  box-shadow:var(--shadow-card);
  text-align:center;
  transition:transform .25s,box-shadow .25s;
}
.hodnota-card:hover{
  transform:translateY(-4px);
  box-shadow:var(--shadow-hover);
}
.hodnota-icon{
  width:56px;height:56px;
  border-radius:50%;
  background:var(--clr-primary-soft);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 20px;
}
.hodnota-icon svg{
  width:24px;height:24px;
  stroke:var(--clr-primary);
  fill:none;
  stroke-width:1.8;
  stroke-linecap:round;
  stroke-linejoin:round;
}
.hodnota-card h3{
  font-family:var(--font-display);
  font-size:var(--font-size-h4);
  font-weight:600;
  color:var(--clr-text-dark);
  margin-bottom:10px;
}
.hodnota-card p{
  font-size:var(--font-size-small);
  color:var(--clr-text-body);
  line-height:1.65;
  margin:0;
}

/* ══ ŘEDITELKA ══ */
.reditelka-section{
  padding:88px 0;
  background:var(--clr-surface);
}
.reditelka-grid{
  display:grid;
  grid-template-columns:1fr 1.5fr;
  gap:72px;
  align-items:center;
}
.reditelka-text h2{margin-bottom:6px;}
.reditelka-title{
  display:block;
  font-family:var(--font-body);
  font-size:var(--font-size-meta);
  font-weight:700;
  letter-spacing:0.06em;
  text-transform:uppercase;
  color:var(--clr-text-muted);
  margin-bottom:24px;
}
blockquote.reditelka-quote{
  font-family:var(--font-display);
  font-size:var(--font-size-perex);
  font-style:italic;
  font-weight:400;
  color:var(--clr-text-muted);
  border-left:3px solid var(--clr-primary);
  padding-left:24px;
  margin:0 0 24px;
  line-height:1.6;
}
.reditelka-text p{
  font-size:var(--font-size-base);
  color:var(--clr-text-body);
  line-height:1.75;
  margin-bottom:14px;
}
.reditelka-tags{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  margin:18px 0 28px;
}
.r-tag{
  font-family:var(--font-body);
  font-size:var(--font-size-meta);
  font-weight:600;
  color:var(--clr-primary);
  background:var(--clr-primary-soft);
  padding:4px 12px;
  border-radius:20px;
}

/* ══ GALERIE ══ */
.galerie-section{padding:88px 0;}
.galerie-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:16px;
}
.galerie-item{
  border-radius:10px;
  background:var(--clr-surface);
  border:1px solid var(--clr-border);
  aspect-ratio:4/3;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:8px;
  text-align:center;
  padding:16px;
  transition:transform .22s,box-shadow .22s;
}
.galerie-item:hover{
  transform:translateY(-3px);
  box-shadow:var(--shadow-hover);
}
.galerie-item svg{
  width:28px;height:28px;
  opacity:0.28;
}
.galerie-item-label{
  font-size:var(--font-size-meta);
  color:var(--clr-text-muted);
  line-height:1.4;
}
.galerie-item-rok{
  font-size:var(--font-size-meta);
  font-style:italic;
  color:var(--clr-text-muted);
}
.galerie-note{
  text-align:center;
  margin-top:14px;
  font-size:var(--font-size-caption);
  color:var(--clr-text-muted);
  font-style:italic;
}

/* ══ CTA ══ */
.cta-section{
  padding:88px 0;
  background:#EDE8E3;
  text-align:center;
  position:relative;
  overflow:hidden;
}
.cta-section::before{
  content:'';position:absolute;
  width:360px;height:360px;border-radius:50%;
  background:rgba(155,66,73,0.08);
  top:-100px;right:-80px;
}
.cta-section::after{
  content:'';position:absolute;
  width:220px;height:220px;border-radius:50%;
  background:rgba(155,66,73,0.05);
  bottom:-50px;left:-50px;
}
.cta-section .container{position:relative;z-index:1;}
.cta-section h2{margin-bottom:14px;}
.cta-section p{
  font-size:var(--font-size-perex);
  color:var(--clr-text-body);
  max-width:540px;
  margin:0 auto 36px;
  line-height:1.65;
}
.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}

/* ══ SECTION LABEL ══ */
.section-label{
  font-family:var(--font-body);
  font-size:var(--font-size-label);
  font-weight:700;
  letter-spacing:0.10em;
  text-transform:uppercase;
  color:var(--clr-primary);
  margin-bottom:12px;
  display:block;
}

/* ══ BUTTONS ══ */
.btn-primary{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--clr-primary);color:#fff;
  font-family:var(--font-body);font-size:var(--font-size-ui);font-weight:600;
  padding:13px 26px;border-radius:var(--radius-btn);
  text-decoration:none;
  transition:background .2s,transform .2s,box-shadow .2s;
}
.btn-primary:hover{
  background:var(--clr-primary-hover);
  transform:translateY(-1px);
  box-shadow:0 4px 16px rgba(155,66,73,0.28);
}
.btn-outline{
  display:inline-flex;align-items:center;gap:8px;
  border:2px solid var(--clr-primary);color:var(--clr-primary);
  font-family:var(--font-body);font-size:var(--font-size-ui);font-weight:600;
  padding:11px 26px;border-radius:var(--radius-btn);
  text-decoration:none;
  transition:background .2s,transform .2s;
}
.btn-outline:hover{
  background:var(--clr-primary-soft);
  transform:translateY(-1px);
}

/* ══ RESPONSIVE ══ */
@media(max-width:1024px){
  .story-grid,.reditelka-grid{gap:48px;}
  .hodnoty-grid{grid-template-columns:repeat(2,1fr);}
  .zavazek-grid{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:768px){
  .story-section,.zavazek-section,.hodnoty-section,
  .reditelka-section,.galerie-section,.cta-section{padding:64px 0;}
  .story-grid{grid-template-columns:1fr;gap:36px;}
  .story-grid.reverse{direction:ltr;}
  .story-year{font-size:56px;}
  .hodnoty-grid{grid-template-columns:1fr;}
  .zavazek-grid{grid-template-columns:1fr;}
  .reditelka-grid{grid-template-columns:1fr;gap:36px;}
  .galerie-grid{grid-template-columns:repeat(2,1fr);}
  .page-hero{padding:56px 0 44px;}
}
@media(max-width:480px){
  .galerie-grid{grid-template-columns:1fr;}
  .cta-btns{flex-direction:column;align-items:center;}
}



/* ══ TIMELINE ══ */
.timeline-section{padding:88px 0;background:var(--clr-bg);}

/* ── LINKA VLEVO ── */
.timeline{
  position:relative;
  max-width:760px;
  margin:0 auto;
  padding-left:52px;   /* místo pro čáru + tečky */
}

/* Šedý track – celá výška */
.timeline::before{
  content:'';
  position:absolute;
  left:16px;
  top:0;bottom:0;
  width:3px;
  background:var(--clr-border);
  border-radius:2px;
}

/* Barevná progress čára – roste JS-em přes CSS var */
.timeline::after{
  content:'';
  position:absolute;
  left:16px;
  top:0;
  width:3px;
  height:var(--tl-progress, 0%);
  background:linear-gradient(to bottom, var(--clr-primary) 0%, var(--clr-green) 100%);
  border-radius:2px;
  transition:height .1s linear;
  z-index:1;
}

/* ── POLOŽKA ── */
.tl-item{
  display:flex;
  align-items:flex-start;
  gap:28px;
  margin-bottom:44px;
  position:relative;
}

/* Tečka na čáře */
.tl-dot{
  position:absolute;
  left:-44px;       /* 52px offset - 8px (polovina tečky) */
  top:24px;
  width:16px;height:16px;
  border-radius:50%;
  background:var(--clr-border);
  border:3px solid var(--clr-bg);
  z-index:2;
  transition:background .4s, transform .4s, box-shadow .4s;
  flex-shrink:0;
}

/* Aktivní tečka (při scroll) */
.tl-item.tl-active .tl-dot{
  background:var(--clr-primary);
  transform:scale(1.3);
  box-shadow:0 0 0 4px rgba(155,66,73,.18);
}
.tl-item.tl-highlight.tl-active .tl-dot{
  background:var(--clr-green);
  box-shadow:0 0 0 5px rgba(91,125,91,.22);
}

/* ── KARTA ── */
.tl-content{
  flex:1;
  background:var(--clr-white);
  border-radius:var(--radius-card);
  border:1px solid var(--clr-border);
  border-left:3px solid var(--clr-border);
  padding:24px 28px;
  box-shadow:var(--shadow-card);
  transition:box-shadow .3s, transform .3s, border-left-color .4s, opacity .4s;
  opacity:.55;
  transform:translateX(10px);
}
.tl-item.tl-active .tl-content{
  opacity:1;
  transform:translateX(0);
  border-left-color:var(--clr-primary);
  box-shadow:var(--shadow-hover);
}
.tl-item.tl-highlight.tl-active .tl-content{
  border-left-color:var(--clr-green);
}
.tl-content:hover{
  box-shadow:0 8px 32px rgba(0,0,0,.13);
  transform:translateX(2px);
}

.tl-year-tag{
  display:inline-block;
  font-size:11px;font-weight:700;
  letter-spacing:.08em;text-transform:uppercase;
  color:var(--clr-primary);
  background:var(--clr-primary-soft);
  padding:3px 10px;border-radius:20px;
  margin-bottom:10px;
}
.tl-item.tl-highlight .tl-year-tag{
  background:var(--clr-green-soft);
  color:var(--clr-green);
}
.tl-content h3{
  font-family:var(--font-display);
  font-size:var(--font-size-subhead);
  font-weight:600;
  color:var(--clr-text-dark);
  margin-bottom:8px;line-height:1.35;
}
.tl-content p{
  font-size:var(--font-size-base);
  color:var(--clr-text-body);
  line-height:1.65;margin:0;
}

/* Odstraníme spacer – už ho nepotřebujeme */
.tl-spacer{display:none;}

@media(max-width:768px){
  .timeline-section{padding:64px 0;}
  .timeline{padding-left:40px;}
  .timeline::before,.timeline::after{left:12px;}
  .tl-dot{left:-34px;}
  .tl-content{padding:20px;}
}

/* ══ RELATED SEKCE – STYL D ══ */
.related-d-section{background:var(--clr-surface);padding:72px 0}
.related-d-section h2{font-family:var(--ff-head);font-size:var(--font-size-h2);font-weight:700;color:var(--clr-primary);margin:0 0 8px}
.related-d-label{font-family:var(--ff-body);font-size:var(--font-size-label);font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--clr-primary);display:block;margin-bottom:12px}
.related-d-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:36px}
.related-d-card{background:#fff;border-radius:var(--radius-card);box-shadow:var(--shadow-card);padding:28px 24px;text-decoration:none;display:flex;flex-direction:column;gap:12px;border-top:3px solid var(--clr-border);transition:box-shadow .22s,transform .22s,border-top-color .22s;color:inherit}
.related-d-card:hover{box-shadow:var(--shadow-hover);transform:translateY(-4px);border-top-color:var(--clr-primary)}
.related-d-card-label{font-family:var(--ff-body);font-size:var(--font-size-label);font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--clr-text-muted)}
.related-d-card-title{font-family:var(--ff-head);font-size:var(--font-size-subhead);font-weight:600;color:var(--clr-text-dark);line-height:1.35}
.related-d-card-desc{font-family:var(--ff-body);font-size:var(--font-size-base);color:var(--clr-text-muted);line-height:1.55;flex:1}
.related-d-card-arrow{display:flex;align-items:center;gap:6px;font-family:var(--ff-body);font-size:var(--font-size-caption);font-weight:600;color:var(--clr-primary);margin-top:4px;transition:gap .18s}
.related-d-card:hover .related-d-card-arrow{gap:10px}
.related-d-card-arrow svg{width:16px;height:16px;flex-shrink:0;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
@media(max-width:1024px){.related-d-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:768px){.related-d-section{padding:56px 0}.related-d-section h2{font-size:var(--font-size-h2-mob)}}
@media(max-width:480px){.related-d-grid{grid-template-columns:1fr}}


/* ══ HERO BUTTONS ══ */
.hero-btn-wrap { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; }
.hero-btn-primary {
  display: inline-flex; align-items: center; gap: 9px;
  background: #fff; color: var(--clr-primary);
  border: 2px solid #fff;
  font-family: var(--ff-body); font-size: var(--font-size-ui); font-weight: 700;
  padding: 14px 28px; border-radius: var(--radius-btn);
  text-decoration: none; transition: background .2s, color .2s, border-color .2s;
  letter-spacing: 0.01em;
}
.hero-btn-primary:hover {
  background: transparent; color: #fff; border-color: #fff;
}
.hero-btn-secondary {
  display: inline-flex; align-items: center; gap: 9px;
  background: transparent; color: #fff;
  border: 2px solid rgba(255,255,255,0.65);
  font-family: var(--ff-body); font-size: var(--font-size-ui); font-weight: 600;
  padding: 14px 28px; border-radius: var(--radius-btn);
  text-decoration: none; transition: background .2s, border-color .2s;
  letter-spacing: 0.01em;
}
.hero-btn-secondary:hover {
  border-color: #fff; background: rgba(255,255,255,0.12);
}
@media(max-width:480px){
  .hero-btn-wrap { flex-direction: column; }
  .hero-btn-primary, .hero-btn-secondary { justify-content: center; }
}

</style>

<!-- ══ 1. HERO ══ --><!-- v2 -->
<section class="page-hero">
  <div class="container">
    <div class="page-hero-inner">
      <span class="page-hero-kicker">O nás</span>
      <h1>Příběh, který začal snem<br><em>o důstojném domově</em></h1>
      <p class="hero-perex">Domov Turovice je registrovaný domov pro seniory v Olomouckém kraji. Vznikl z prázdné budovy – přes covidovou pandemii – až po otevření v srpnu 2025. Za každým rozhodnutím stojí jeden člověk a 22 let praxe v péči o seniory.</p>
            <div class="hero-btn-wrap">
