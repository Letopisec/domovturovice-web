<script>
  {
    const track = document.getElementById('tlTrack') as HTMLElement | null;
    if (track) {
      const items = Array.from(track.querySelectorAll('.tl-item')) as HTMLElement[];
      const trackRect = () => track.getBoundingClientRect();

      function update() {
        const tr = track.getBoundingClientRect();
        const winH = window.innerHeight;

        // Výška progress čáry: kolik trackу prorolováno přes střed viewportu
        const scrolled = winH * 0.65 - tr.top;
        const total = tr.height;
        const pct = Math.max(0, Math.min(100, (scrolled / total) * 100));
        track.style.setProperty('--tl-progress', pct + '%');

        // Aktivace jednotlivých položek
        items.forEach((item) => {
          const dot = item.querySelector('.tl-dot') as HTMLElement | null;
          const rect = item.getBoundingClientRect();
          const dotY = rect.top + 28; // tečka je 28px od vrcholu položky
          if (dotY < winH * 0.72) {
            item.classList.add('tl-active');
          } else {
            item.classList.remove('tl-active');
          }
        });
      }

      // První průchod
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update, { passive: true });
    }
  }
</script>

<script>
  {
    const track = document.getElementById('blogTrackPribeh') as HTMLElement;
    const dotsContainer = document.getElementById('pribehBlogDots') as HTMLElement;
    const prevBtn = document.getElementById('pribehBlogPrev');
    const nextBtn = document.getElementById('pribehBlogNext');
    if (track && dotsContainer) {
      const cards = track.querySelectorAll('.blog-card');
      const total = cards.length;
      const visibleCount = () => window.innerWidth > 1024 ? 3 : window.innerWidth > 768 ? 2 : 1;
      let current = 0;
      let autoInterval: ReturnType<typeof setInterval>;

      function maxSlide() { return Math.max(0, total - visibleCount()); }

      function buildDots() {
        dotsContainer.innerHTML = '';
        for (let i = 0; i <= maxSlide(); i++) {
          const dot = document.createElement('button');
          dot.className = 'blog-dot' + (i === current ? ' active' : '');
          dot.setAttribute('aria-label', `Příspěvek ${i + 1}`);
          dot.addEventListener('click', () => goTo(i));
          dotsContainer.appendChild(dot);
        }
      }

      function goTo(idx: number) {
        current = Math.max(0, Math.min(idx, maxSlide()));
        const cardWidth = (cards[0] as HTMLElement).offsetWidth + 16;
        track.style.transform = `translateX(-${current * cardWidth}px)`;
        dotsContainer.querySelectorAll('.blog-dot').forEach((d, i) => {
          d.classList.toggle('active', i === current);
        });
      }

      function startAuto() {
        autoInterval = setInterval(() => goTo(current < maxSlide() ? current + 1 : 0), 4000);
      }

      track.addEventListener('mouseenter', () => clearInterval(autoInterval));
      track.addEventListener('mouseleave', startAuto);
      prevBtn?.addEventListener('click', () => goTo(current - 1));
      nextBtn?.addEventListener('click', () => goTo(current + 1));

      buildDots();
      startAuto();
      window.addEventListener('resize', () => { buildDots(); goTo(Math.min(current, maxSlide())); });
    }
  }
</script>

