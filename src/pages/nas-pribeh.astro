HERO_CSS: OK
---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Náš příběh – Domov Turovice, domov pro seniory v Olomouckém kraji"
  description="Domov Turovice vznikl ze snu o důstojném domově pro seniory. Příběh zapsaného ústavu v Turovicích, který otevřel brány 1. 8. 2025 v okrese Přerov."
>

<style>
/* ══ HERO ══ */
.page-hero{
  background:linear-gradient(135deg,var(--clr-primary) 0%,#7a3238 100%);
  color:#fff;
  padding:72px 0 60px;
  position:relative;
  overflow:hidden;
}
.page-hero::after{
  content:'';
  position:absolute;
  right:-80px;top:-80px;
  width:400px;height:400px;
  border-radius:50%;
  background:rgba(255,255,255,.06);
  pointer-events:none;
}
.page-hero-inner{
  position:relative;
  z-index:2;
  max-width:680px;
}
.page-hero-kicker{
  display:inline-block;
  font-family:var(--font-body);
  font-size:var(--font-size-label);
  font-weight:700;
  letter-spacing:0.10em;
  text-transform:uppercase;
  color:rgba(255,255,255,0.70);
  margin-bottom:14px;
}
.page-hero h1{
  color:#fff;
  margin-bottom:16px;
}
.page-hero h1 em{
  font-style:italic;
  color:rgba(255,255,255,0.80);
}
.hero-perex{
  font-size:var(--font-size-perex);
  color:rgba(255,255,255,0.88);
  line-height:1.6;
  max-width:580px;
  margin:0 0 28px;
}
.hero-cta{
  display:inline-flex;
  align-items:center;
  gap:8px;
  background:rgba(255,255,255,0.15);
  border:1px solid rgba(255,255,255,0.30);
  color:#fff;
  font-family:var(--font-body);
  font-size:var(--font-size-ui);
  font-weight:600;
  padding:11px 22px;
  border-radius:var(--radius-btn);
  text-decoration:none;
  transition:background .2s;
}
.hero-cta:hover{background:rgba(255,255,255,0.25);}

/* ══ STORY SECTIONS ══ */
.story-section{padding:88px 0;}
.story-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:72px;
  align-items:center;
}
.story-grid.reverse{direction:rtl;}
.story-grid.reverse > *{direction:ltr;}

.story-year{
  font-family:var(--font-display);
  font-size:56px;
  font-weight:700;
  color:var(--clr-border);
  line-height:1;
  margin-bottom:-12px;
  display:block;
  letter-spacing:-0.02em;
}
.story-text h2{margin-bottom:20px;}
.story-text p{
  font-size:var(--font-size-base);
  color:var(--clr-text-body);
  line-height:1.75;
  margin-bottom:16px;
}
.story-text p:last-child{margin-bottom:0;}

/* ══ PHOTO PLACEHOLDER ══ */
.photo-slot{
  border-radius:var(--radius-card);
  background:var(--clr-surface);
  border:1px solid var(--clr-border);
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:10px;
  color:var(--clr-text-muted);
  text-align:center;
  padding:32px 24px;
}
.photo-slot svg{
  width:36px;height:36px;
  opacity:0.30;
  flex-shrink:0;
}
.photo-slot-label{
  font-size:var(--font-size-caption);
  line-height:1.5;
  color:var(--clr-text-muted);
}
.photo-slot-dim{
  font-size:var(--font-size-meta);
  font-weight:700;
  color:var(--clr-primary);
  background:var(--clr-primary-soft);
  padding:3px 10px;
  border-radius:20px;
  margin-top:4px;
}
/* portrait = ředitelka */
.photo-slot.portrait{aspect-ratio:3/4;}
/* landscape = story */
.photo-slot.landscape{aspect-ratio:4/3;}

/* ══ ZÁVAZEK ══ */
.zavazek-section{
  padding:88px 0;
  background:var(--clr-primary-soft);
  position:relative;
  overflow:hidden;
}
.zavazek-section::before{
  content:'';position:absolute;
  width:340px;height:340px;border-radius:50%;
  background:rgba(155,66,73,0.06);
  top:-80px;right:-60px;
}
.zavazek-section::after{
  content:'';position:absolute;
  width:200px;height:200px;border-radius:50%;
  background:rgba(155,66,73,0.04);
  bottom:-40px;left:-40px;
}
.zavazek-inner{
  max-width:820px;
  margin:0 auto;
  text-align:center;
  position:relative;
  z-index:1;
}
.zavazek-inner h2{margin-bottom:12px;}
.zavazek-lead{
  font-size:var(--font-size-base);
  color:var(--clr-text-body);
  line-height:1.7;
  margin-bottom:0;
}
.zavazek-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:24px;
  text-align:left;
  margin-top:40px;
}
.zavazek-card{
  background:var(--clr-white);
  border-radius:var(--radius-card);
  padding:28px 24px;
  box-shadow:var(--shadow-card);
  border-top:3px solid var(--clr-primary);
}
.zavazek-card h3{
  font-family:var(--font-display);
  font-size:var(--font-size-h4);
  font-weight:600;
  color:var(--clr-text-dark);
  margin-bottom:10px;
}
.zavazek-card p{
  font-size:var(--font-size-small);
  color:var(--clr-text-body);
  line-height:1.65;
  margin:0;
}

/* ══ HODNOTY ══ */
.hodnoty-section{padding:88px 0;}
.section-intro{
  text-align:center;
  max-width:580px;
  margin:0 auto 52px;
}
.section-intro h2{margin-bottom:14px;}
.section-intro p{
  font-size:var(--font-size-base);
  color:var(--clr-text-muted);
  line-height:1.7;
  margin:0;
}
.hodnoty-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:24px;
}
.hodnota-card{
  background:var(--clr-bg);
  border-radius:var(--radius-card);
  padding:36px 28px;
  box-shadow:var(--shadow-card);
  text-align:center;
  transition:transform .25s,box-shadow .25s;
}
.hodnota-card:hover{
  transform:translateY(-4px);
  box-shadow:var(--shadow-hover);
}
.hodnota-icon{
  width:56px;height:56px;
  border-radius:50%;
  background:var(--clr-primary-soft);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 20px;
}
.hodnota-icon svg{
  width:24px;height:24px;
  stroke:var(--clr-primary);
  fill:none;
  stroke-width:1.8;
  stroke-linecap:round;
  stroke-linejoin:round;
}
.hodnota-card h3{
  font-family:var(--font-display);
  font-size:var(--font-size-h4);
  font-weight:600;
  color:var(--clr-text-dark);
  margin-bottom:10px;
}
.hodnota-card p{
  font-size:var(--font-size-small);
  color:var(--clr-text-body);
  line-height:1.65;
  margin:0;
}

/* ══ ŘEDITELKA ══ */
.reditelka-section{
  padding:88px 0;
  background:var(--clr-surface);
}
.reditelka-grid{
  display:grid;
  grid-template-columns:1fr 1.5fr;
  gap:72px;
  align-items:center;
}
.reditelka-text h2{margin-bottom:6px;}
.reditelka-title{
  display:block;
  font-family:var(--font-body);
  font-size:var(--font-size-meta);
  font-weight:700;
  letter-spacing:0.06em;
  text-transform:uppercase;
  color:var(--clr-text-muted);
  margin-bottom:24px;
}
blockquote.reditelka-quote{
  font-family:var(--font-display);
  font-size:var(--font-size-perex);
  font-style:italic;
  font-weight:400;
  color:var(--clr-text-muted);
  border-left:3px solid var(--clr-primary);
  padding-left:24px;
  margin:0 0 24px;
  line-height:1.6;
}
.reditelka-text p{
  font-size:var(--font-size-base);
  color:var(--clr-text-body);
  line-height:1.75;
  margin-bottom:14px;
}
.reditelka-tags{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
  margin:18px 0 28px;
}
.r-tag{
  font-family:var(--font-body);
  font-size:var(--font-size-meta);
  font-weight:600;
  color:var(--clr-primary);
  background:var(--clr-primary-soft);
  padding:4px 12px;
  border-radius:20px;
}

/* ══ GALERIE ══ */
.galerie-section{padding:88px 0;}
.galerie-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:16px;
}
.galerie-item{
  border-radius:10px;
  background:var(--clr-surface);
  border:1px solid var(--clr-border);
  aspect-ratio:4/3;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:8px;
  text-align:center;
  padding:16px;
  transition:transform .22s,box-shadow .22s;
}
.galerie-item:hover{
  transform:translateY(-3px);
  box-shadow:var(--shadow-hover);
}
.galerie-item svg{
  width:28px;height:28px;
  opacity:0.28;
}
.galerie-item-label{
  font-size:var(--font-size-meta);
  color:var(--clr-text-muted);
  line-height:1.4;
}
.galerie-item-rok{
  font-size:var(--font-size-meta);
  font-style:italic;
  color:var(--clr-text-muted);
}
.galerie-note{
  text-align:center;
  margin-top:14px;
  font-size:var(--font-size-caption);
  color:var(--clr-text-muted);
  font-style:italic;
}

/* ══ CTA ══ */
.cta-section{
  padding:88px 0;
  background:#EDE8E3;
  text-align:center;
  position:relative;
  overflow:hidden;
}
.cta-section::before{
  content:'';position:absolute;
  width:360px;height:360px;border-radius:50%;
  background:rgba(155,66,73,0.08);
  top:-100px;right:-80px;
}
.cta-section::after{
  content:'';position:absolute;
  width:220px;height:220px;border-radius:50%;
  background:rgba(155,66,73,0.05);
  bottom:-50px;left:-50px;
}
.cta-section .container{position:relative;z-index:1;}
.cta-section h2{margin-bottom:14px;}
.cta-section p{
  font-size:var(--font-size-perex);
  color:var(--clr-text-body);
  max-width:540px;
  margin:0 auto 36px;
  line-height:1.65;
}
.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}

/* ══ SECTION LABEL ══ */
.section-label{
  font-family:var(--font-body);
  font-size:var(--font-size-label);
  font-weight:700;
  letter-spacing:0.10em;
  text-transform:uppercase;
  color:var(--clr-primary);
  margin-bottom:12px;
  display:block;
}

/* ══ BUTTONS ══ */
.btn-primary{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--clr-primary);color:#fff;
  font-family:var(--font-body);font-size:var(--font-size-ui);font-weight:600;
  padding:13px 26px;border-radius:var(--radius-btn);
  text-decoration:none;
  transition:background .2s,transform .2s,box-shadow .2s;
}
.btn-primary:hover{
  background:var(--clr-primary-hover);
  transform:translateY(-1px);
  box-shadow:0 4px 16px rgba(155,66,73,0.28);
}
.btn-outline{
  display:inline-flex;align-items:center;gap:8px;
  border:2px solid var(--clr-primary);color:var(--clr-primary);
  font-family:var(--font-body);font-size:var(--font-size-ui);font-weight:600;
  padding:11px 26px;border-radius:var(--radius-btn);
  text-decoration:none;
  transition:background .2s,transform .2s;
}
.btn-outline:hover{
  background:var(--clr-primary-soft);
  transform:translateY(-1px);
}

/* ══ RESPONSIVE ══ */
@media(max-width:1024px){
  .story-grid,.reditelka-grid{gap:48px;}
  .hodnoty-grid{grid-template-columns:repeat(2,1fr);}
  .zavazek-grid{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:768px){
  .story-section,.zavazek-section,.hodnoty-section,
  .reditelka-section,.galerie-section,.cta-section{padding:64px 0;}
  .story-grid{grid-template-columns:1fr;gap:36px;}
  .story-grid.reverse{direction:ltr;}
  .story-year{font-size:56px;}
  .hodnoty-grid{grid-template-columns:1fr;}
  .zavazek-grid{grid-template-columns:1fr;}
  .reditelka-grid{grid-template-columns:1fr;gap:36px;}
  .galerie-grid{grid-template-columns:repeat(2,1fr);}
  .page-hero{padding:56px 0 44px;}
}
@media(max-width:480px){
  .galerie-grid{grid-template-columns:1fr;}
  .cta-btns{flex-direction:column;align-items:center;}
}

/* ══ PROLINKOVÁNÍ ══ */
.prolinks-section{
  padding:72px 0;
  background:var(--clr-surface);
}
.prolinks-grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:16px;
}
.prolink-card{
  display:flex;
  align-items:center;
  gap:20px;
  background:var(--clr-white);
  border-radius:var(--radius-card);
  padding:24px 28px;
  text-decoration:none;
  box-shadow:var(--shadow-card);
  border:1px solid var(--clr-border);
  border-left:3px solid var(--clr-border);
  transition:border-color .2s,box-shadow .2s,transform .2s;
}
.prolink-card:hover{
  border-left-color:var(--clr-primary);
  box-shadow:var(--shadow-hover);
  transform:translateY(-2px);
}
.prolink-card.prolink-primary{
  border-left-color:var(--clr-primary);
}
.prolink-icon{
  width:44px;height:44px;flex-shrink:0;
  border-radius:10px;
  background:var(--clr-primary-soft);
  display:flex;align-items:center;justify-content:center;
}
.prolink-icon svg{
  width:22px;height:22px;
  stroke:var(--clr-primary);
}
.prolink-text{flex:1;}
.prolink-text h3{
  font-family:var(--font-display);
  font-size:var(--font-size-h4);
  font-weight:600;
  color:var(--clr-text-dark);
  margin-bottom:4px;
  transition:color .2s;
}
.prolink-card:hover .prolink-text h3{color:var(--clr-primary);}
.prolink-text p{
  font-size:var(--font-size-small);
  color:var(--clr-text-muted);
  line-height:1.55;
  margin:0;
}
.prolink-arrow{
  width:20px;height:20px;flex-shrink:0;
  stroke:var(--clr-border);
  transition:stroke .2s,transform .2s;
}
.prolink-card:hover .prolink-arrow{
  stroke:var(--clr-primary);
  transform:translateX(4px);
}
/* blog section on subpage needs white bg */
.blog-section{background:var(--clr-bg);}
@media(max-width:768px){
  .prolinks-grid{grid-template-columns:1fr;}
  .prolinks-section{padding:56px 0;}
}
</style>

<!-- ══ 1. HERO ══ -->
<section class="page-hero">
  <div class="container">
    <div class="page-hero-inner">
      <span class="page-hero-kicker">O nás</span>
      <h1>Příběh, který začal snem<br><em>o důstojném domově</em></h1>
      <p class="hero-perex">Domov Turovice je registrovaný domov pro seniory v Olomouckém kraji. Vznik z prázdné budovy, přes covidovou pandemii, až k otevření v srpnu 2025.</p>
      <a href="#pribeh" class="hero-cta">
        Číst příběh
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- ══ 2. VZNIK 2016 ══ -->
<section id="pribeh" class="story-section" style="background:var(--clr-bg);">
  <div class="container">
    <div class="story-grid">
      <div class="story-text">
        <span class="section-label">2016 – 2017</span>
        <span class="story-year">2016</span>
        <h2>Prázdná budova a jeden nápad, který vše změnil</h2>
        <p>V roce 2016 vydražila soukromá osoba nedokončenou obecní budovu v Turovicích. Budova stála prázdná a čekala na svůj osud. Různé možnosti přicházely a odcházely – až do chvíle, kdy zazněl záměr Ziny Filip Dadlíkové.</p>
        <p>Myšlenka byla jednoduchá a zároveň velmi konkrétní: vybudovat domov pro seniory, který bude skutečným domovem. Ne ústavem, ne čekárnou. Místem, kde má každý člověk svůj prostor, svůj rytmus a svou důstojnost.</p>
        <p>Investor záměr přijal. V srpnu 2017 byl založen <strong>zapsaný ústav Domov Turovice</strong>. Zakladatelkou se stala Michaela Hubačová, dcera investora. Přípravy mohly začít.</p>
      </div>
      <div>
        <div class="photo-slot landscape">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span class="photo-slot-label">Budova před rekonstrukcí nebo první skica záměru</span>
          <span class="photo-slot-dim">800 × 600 px</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ 3. STAVBA 2017–2025 ══ -->
<section class="story-section" style="background:var(--clr-surface);">
  <div class="container">
    <div class="story-grid reverse">
      <div class="story-text">
        <span class="section-label">2017 – 2025</span>
        <span class="story-year">2017</span>
        <h2>Dlouhá cesta od vize ke skutečnosti</h2>
        <p>Následovaly roky příprav. Projektanti převáděli odborné vize Ziny Filip Dadlíkové do konkrétních řešení. Hledaly se vhodné stavební firmy. Pak přišla covidová pandemie a vše zpomalila.</p>
        <p>Investor však ve svém úsilí nepolevil. Stavební práce postupovaly, byť pomalu. Poté přišlo období kontrol, revizí a schvalování. Nesoulady mezi projektovou dokumentací a požadavky komisařů HZS si vyžádaly opravy a trpělivé čekání.</p>
        <p>Po celou dobu byl tým zaměstnanců připraven. Pokoje čekaly vystlané. Kuchyně vybavená. Jen kolaudace nepřicházela. Byla to zkouška odhodlání, které nakonec obstálo.</p>
      </div>
      <div>
        <div class="photo-slot landscape">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span class="photo-slot-label">Průběh rekonstrukce nebo stavba interiérů</span>
          <span class="photo-slot-dim">800 × 600 px</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ 4. OTEVŘENÍ 2025 ══ -->
<section id="pribeh" class="story-section" style="background:var(--clr-bg);">
  <div class="container">
    <div class="story-grid">
      <div class="story-text">
        <span class="section-label">1. 8. 2025</span>
        <span class="story-year">2025</span>
        <h2>Přišla první klientka. Domov otevřel brány.</h2>
        <p>Dne 1. 8. 2025 přijela do Turovic první obyvatelka nového domova. Čekaly na ni vzdušné chodby, výhled do zahrady a jednolůžkový pokoj o velikosti 12,6 m². Polohovatelná postel, uzamykatelná skříň, televize. A hlavně – lidé, kteří na ni celé roky čekali.</p>
        <p>Domov Turovice poskytuje pobytové sociální služby dle § 49 zákona č. 108/2006 Sb. pro seniory se sníženou soběstačností. Kapacita domova je <strong>104 klientů</strong> ve vzájemně propojených budovách A, B, C.</p>
        <p>Každý klient má k dispozici byt – dva samostatné pokoje, vlastní sociální zázemí a prostornou předsíň. Některé byty mají lodžii nebo přístup na bezbariérovou terasu. To vše v obci Turovice, v tiché krajině okresu Přerov.</p>
      </div>
      <div>
        <div class="photo-slot landscape">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span class="photo-slot-label">Otevření / první klientka / interiér pokoje nebo zahrada</span>
          <span class="photo-slot-dim">800 × 600 px</span>
        </div>
      </div>
    </div>
  </div>
</section>

