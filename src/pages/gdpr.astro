---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Ochrana osobních údajů – Domov Turovice"
  description="Informace o zpracování osobních údajů klientů a jejich rodinných příslušníků v Domově Turovice dle nařízení GDPR."
>


<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{"@type":"Question","name":"Kdo má přístup k mým osobním údajům?","acceptedAnswer":{"@type":"Answer","text":"K vašim osobním údajům mají přístup pouze zaměstnanci domova, kteří je potřebují k zajištění péče. Údaje neposkytujeme třetím stranám bez vašeho souhlasu, s výjimkou zákonných povinností."}},{"@type":"Question","name":"Mohu požádat o výmaz svých údajů?","acceptedAnswer":{"@type":"Answer","text":"Právo na výmaz můžete uplatnit, pokud pominul účel zpracování. Některé údaje jsme však povinni uchovávat ze zákona po stanovenou dobu."}},{"@type":"Question","name":"Jak mohu vznést námitku proti zpracování?","acceptedAnswer":{"@type":"Answer","text":"Námitku podejte písemně nebo e-mailem na adresu info@domovturovice.cz. Odpovíme vám do 30 dnů."}},{"@type":"Question","name":"Kde si mohu stěžovat na zpracování údajů?","acceptedAnswer":{"@type":"Answer","text":"Stížnost můžete podat u Úřadu pro ochranu osobních údajů (uoou.cz)."}}]
}
</script>

<style>

.page-hero {
  background: linear-gradient(135deg, var(--clr-primary) 0%, #7a3238 100%);
  color: #fff;
  padding: 72px 0 56px;
  position: relative;
  overflow: hidden;
}
.page-hero::after {
  content: '';
  position: absolute;
  right: -80px; top: -80px;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: rgba(255,255,255,.06);
  pointer-events: none;
}
.page-hero-inner { position: relative; z-index: 2; max-width: 640px; }
.page-hero-kicker {
  display: inline-block;
  font-size: var(--font-size-label);
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgba(255,255,255,.75);
  margin-bottom: 14px;
}
.page-hero h1 {
  font-family: var(--ff-head);
  font-size: clamp(1.9rem, 4vw, 2.8rem);
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 16px;
}
.page-hero-perex {
  font-size: var(--font-size-perex);
  line-height: 1.65;
  color: rgba(255,255,255,.88);
  max-width: 580px;
  margin: 0;
}
.page-hero-meta {
  display: flex;
  gap: 24px;
  margin-top: 20px;
  flex-wrap: wrap;
}
.page-hero-meta-item {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: var(--font-size-meta);
  color: rgba(255,255,255,.7);
}
.page-hero-meta-item svg {
  width: 14px; height: 14px;
  fill: none;
  stroke: rgba(255,255,255,.7);
  stroke-width: 2;
  stroke-linecap: round;
  flex-shrink: 0;
}

.single-layout { padding: 60px 0 80px; background: var(--clr-bg); }
.single-grid {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 48px;
  align-items: start;
}

.update-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: var(--clr-green-soft);
  color: var(--clr-green);
  font-size: var(--font-size-meta);
  font-weight: 700;
  padding: 6px 14px;
  border-radius: 20px;
  margin-bottom: 28px;
}
.update-badge svg {
  width: 14px; height: 14px;
  fill: none;
  stroke: var(--clr-green);
  stroke-width: 2;
  stroke-linecap: round;
  flex-shrink: 0;
}

.info-box {
  background: var(--clr-primary-soft);
  border-left: 4px solid var(--clr-primary);
  border-radius: 0 8px 8px 0;
  padding: 18px 22px;
  margin: 0 0 32px;
  font-size: var(--font-size-small);
  line-height: 1.6;
  color: var(--clr-text-body);
}
.info-box strong { color: var(--clr-primary); }

.article-prose { font-size: var(--font-size-ui); line-height: 1.78; color: var(--clr-text-body); }
.article-prose h2 {
  font-family: var(--ff-head);
  font-size: 1.45rem;
  font-weight: 700;
  color: var(--clr-heading);
  margin: 40px 0 14px;
  line-height: 1.3;
  padding-bottom: 10px;
  border-bottom: 2px solid var(--clr-primary-soft);
}
.article-prose h3 {
  font-family: var(--ff-head);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--clr-heading);
  margin: 28px 0 10px;
}
.article-prose p { margin: 0 0 18px; }
.article-prose ul, .article-prose ol {
  margin: 0 0 20px 0;
  padding-left: 0;
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.article-prose ul li, .article-prose ol li {
  padding-left: 24px;
  position: relative;
  line-height: 1.65;
}
.article-prose ul li::before {
  content: '';
  position: absolute;
  left: 0; top: 10px;
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--clr-primary);
}
.article-prose ol { counter-reset: ol-counter; }
.article-prose ol li { counter-increment: ol-counter; }
.article-prose ol li::before {
  content: counter(ol-counter) ".";
  position: absolute;
  left: 0;
  font-weight: 700;
  color: var(--clr-primary);
  font-size: var(--font-size-meta);
}
.article-prose strong { font-weight: 700; color: var(--clr-text-dark); }
.article-prose a { color: var(--clr-primary); font-weight: 600; }
.article-prose a:hover { text-decoration: underline; }

.faq-section {
  margin-top: 48px;
  padding-top: 40px;
  border-top: 2px solid var(--clr-border);
}
.faq-section h2 {
  font-family: var(--ff-head);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--clr-heading);
  margin-bottom: 24px;
}
.faq-item {
  border: 1.5px solid var(--clr-border);
  border-radius: 10px;
  margin-bottom: 10px;
  overflow: hidden;
  background: #fff;
}
.faq-question {
  width: 100%;
  text-align: left;
  padding: 18px 20px;
  background: none;
  border: none;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  font-family: var(--ff-body);
  font-size: var(--font-size-ui);
  font-weight: 600;
  color: var(--clr-text-dark);
  transition: background .15s, color .15s;
}
.faq-question:hover { background: var(--clr-primary-soft); color: var(--clr-primary); }
.faq-question[aria-expanded="true"] { background: var(--clr-primary-soft); color: var(--clr-primary); }
.faq-icon { width: 20px; height: 20px; flex-shrink: 0; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; transition: transform .2s; }
.faq-question[aria-expanded="true"] .faq-icon { transform: rotate(45deg); }
.faq-answer {
  padding: 4px 20px 18px;
  font-size: var(--font-size-small);
  line-height: 1.7;
  color: var(--clr-text-body);
  border-top: 1px solid var(--clr-border);
}

.sidebar { position: sticky; top: 90px; }
.sidebar-widget {
  background: #fff;
  border: 1.5px solid var(--clr-border);
  border-radius: var(--radius-card);
  padding: 22px;
  margin-bottom: 20px;
}
.sidebar-widget-h {
  font-family: var(--ff-head);
  font-size: 1rem;
  font-weight: 700;
  color: var(--clr-heading);
  margin: 0 0 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--clr-border);
}
.btn-pdf {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  padding: 13px 18px;
  background: var(--clr-primary);
  color: white !important;
  border-radius: 8px;
  text-decoration: none !important;
  font-weight: 700;
  font-size: var(--font-size-small);
  transition: background .2s;
  margin-bottom: 10px;
}
.btn-pdf:hover { background: var(--clr-primary-hover); }
.btn-pdf svg { width: 18px; height: 18px; fill: none; stroke: white; stroke-width: 2; stroke-linecap: round; flex-shrink: 0; }
.pdf-note { font-size: var(--font-size-label); color: var(--clr-text-muted); text-align: center; line-height: 1.5; }
.doc-links { list-style: none; display: flex; flex-direction: column; gap: 4px; }
.doc-links a {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 10px;
  border-radius: 7px;
  text-decoration: none;
  color: var(--clr-text-body);
  font-size: var(--font-size-caption);
  font-weight: 600;
  transition: background .15s, color .15s;
}
.doc-links a:hover { background: var(--clr-primary-soft); color: var(--clr-primary); }
.doc-links a.active-doc { background: var(--clr-primary-soft); color: var(--clr-primary); }
.doc-links svg { width: 15px; height: 15px; fill: none; stroke: var(--clr-primary); stroke-width: 2; stroke-linecap: round; flex-shrink: 0; }
.contact-widget {
  background: var(--clr-primary);
  border-radius: var(--radius-card);
  padding: 24px;
  color: #fff;
}
.contact-widget h3 {
  font-family: var(--ff-head);
  font-size: 1.1rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 10px;
}
.contact-widget p { font-size: var(--font-size-caption); line-height: 1.6; color: rgba(255,255,255,.85); margin: 0 0 18px; }
.cw-btn {
  display: block;
  background: #fff;
  color: var(--clr-primary);
  text-align: center;
  padding: 10px;
  border-radius: 8px;
  font-weight: 700;
  font-size: var(--font-size-caption);
  text-decoration: none;
  margin-bottom: 10px;
  transition: opacity .2s;
}
.cw-btn:hover { opacity: .9; text-decoration: none; }
.cw-phone {
  display: block;
  text-align: center;
  color: rgba(255,255,255,.9);
  font-weight: 600;
  font-size: var(--font-size-small);
  text-decoration: none;
}
.cw-phone:hover { color: #fff; }

.cta-section { background: #EDE8E3; padding: 80px 0; text-align: center; }
.cta-inner { max-width: 560px; margin: 0 auto; }
.cta-inner h2 {
  font-family: var(--ff-head);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  font-weight: 700;
  color: var(--clr-primary);
  margin-bottom: 14px;
}
.cta-inner p { font-size: var(--font-size-perex); color: var(--clr-text-body); margin-bottom: 32px; line-height: 1.65; }
.cta-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

.related-links { padding: 56px 0; background: var(--clr-bg); }
.related-links h2 {
  font-family: var(--ff-head);
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--clr-heading);
  margin: 0 0 24px;
}
.related-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}
.related-item {
  display: flex; align-items: center; gap: 12px;
  padding: 16px 18px; background: #fff;
  border: 1.5px solid var(--clr-border); border-radius: 10px;
  text-decoration: none; color: var(--clr-heading);
  font-weight: 600; font-size: var(--font-size-ui); transition: all .2s;
}
.related-item:hover { border-color: var(--clr-primary); color: var(--clr-primary); box-shadow: 0 4px 14px rgba(155,66,73,.1); }
.related-item svg { width: 20px; height: 20px; stroke: var(--clr-primary); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }

@media (max-width: 900px) {
  .single-grid { grid-template-columns: 1fr; }
  .sidebar { position: static; }
  .related-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .single-layout { padding: 40px 0 56px; }
}
@media (max-width: 480px) {
  .related-grid { grid-template-columns: 1fr; }
}

</style>

<!-- PAGE HERO -->
<section class="page-hero">
  <div class="container">
    <div class="page-hero-inner">
      <span class="page-hero-kicker">Povinné dokumenty</span>
      <h1>Ochrana osobních údajů</h1>
      <p class="page-hero-perex">Informace o tom, jak Domov Turovice zpracovává osobní údaje klientů, jejich rodinných příslušníků a návštěvníků webu dle nařízení EU 2016/679 (GDPR).</p>
      <div class="page-hero-meta">
        <span class="page-hero-meta-item">
          <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Aktualizováno: leden 2026
        </span>
        <span class="page-hero-meta-item"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>Ke stažení jako PDF</span>
        <span class="page-hero-meta-item">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          Platnost od 25. 5. 2018
        </span>
      </div>
    </div>
  </div>
</section>

<!-- MAIN -->
<main class="single-layout">
  <div class="container">
    <div class="single-grid">

      <!-- ARTICLE -->
      <article>
        <div class="update-badge">
          <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Aktuální verze · platnost od 25. 5. 2018
        </div>

        <div class="info-box">
          Tento dokument je zveřejněn v souladu s <strong>nařízení EU č. 2016/679 (GDPR)</strong>.
        </div>

        <div class="article-prose">
          
          <h2>1. Správce osobních údajů</h2>
